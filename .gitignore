# Függőségek
/vendor/
/node_modules/

# Környezet és titkok
.env
.env.*
!.env.example

# Tárolt fájlok, naplók, cache, feltöltések (webgyökéren kívül)
/storage/logs/*
!/storage/logs/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep
/storage/uploads/*
!/storage/uploads/.gitkeep
/storage/sessions/
/storage/database.sqlite

# Valós ügyféladat és sablonok (SOHA ne kerüljön gitbe — érzékeny személyes adat)
/private-data/
/templates-pdf/
*.xlsx
*.pdf

# Deploy — a helyi SSH-konfig, kulcsok és jegyzetek (titkok) nem kerülnek a repóba
/deploy/deploy.config
/deploy.md
/deploy/.secret
/deploy/keys/
/deploy/env.production

# Teszt-cache
/.phpunit.cache/

# Eszközök
/composer.phar
/composer-install.log
/composer-require.log
/public/build/

