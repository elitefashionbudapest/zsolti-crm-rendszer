{% extends 'layouts/admin.twig' %}
{% block title %}AI tanácsadó szerkesztő — {{ app_name }}{% endblock %}

{% block main %}
<div x-data="advisoryEditor()" x-cloak>
  <div class="mb-5 flex items-center gap-3">
    <a href="/admin/tanacsadas" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">AI tanácsadó szerkesztő</h1>
      <p class="mt-0.5 text-[13px] text-muted">Add meg, miről generáljon, állítsd be az arculatot, majd szerkeszd vizuálisan, mielőtt publikálod.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-5">
    {# Generátor vezérlők #}
    <div class="lg:col-span-2">
      <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-card">
        <h2 class="flex items-center gap-2 text-[15px] font-bold text-ink"><i data-lucide="sparkles" class="h-[18px] w-[18px] text-teal"></i> Tartalom generálása</h2>

        <label class="mt-4 mb-1.5 block text-[13px] font-semibold text-ink">Miről generáljon? (brief)</label>
        <textarea x-model="brief" rows="4" placeholder="Pl. Mire figyeljen az ügyfél lakásbiztosítás kötésekor — fedezetek, önrész, gyakori hibák." class="w-full rounded-xl border border-slate-200 bg-surface px-3.5 py-2.5 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15"></textarea>

        <div class="mt-4 grid grid-cols-2 gap-3">
          <div>
            <label class="mb-1.5 block text-[13px] font-semibold text-ink">Hangnem</label>
            <select x-model="tone" class="w-full rounded-xl border border-slate-200 bg-surface px-3 py-2.5 text-[13.5px] outline-none focus:border-teal">
              {% for code, label in tones %}<option value="{{ code }}">{{ label }}</option>{% endfor %}
            </select>
          </div>
          <div>
            <label class="mb-1.5 block text-[13px] font-semibold text-ink">Hossz</label>
            <select x-model="length" class="w-full rounded-xl border border-slate-200 bg-surface px-3 py-2.5 text-[13.5px] outline-none focus:border-teal">
              {% for code, label in lengths %}<option value="{{ code }}">{{ label }}</option>{% endfor %}
            </select>
          </div>
        </div>

        <label class="mt-4 mb-1.5 block text-[13px] font-semibold text-ink">Célközönség</label>
        <input type="text" x-model="audience" placeholder="Pl. első lakásvásárlók" class="w-full rounded-xl border border-slate-200 bg-surface px-3.5 py-2.5 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">

        <div class="mt-4">
          <label class="mb-1.5 block text-[13px] font-semibold text-ink">Arculat — kiemelő szín</label>
          <div class="flex items-center gap-3">
            <input type="color" x-model="accent" class="h-10 w-14 cursor-pointer rounded-lg border border-slate-200 bg-white">
            <span class="text-[13px] font-medium text-muted" x-text="accent"></span>
          </div>
        </div>

        <label class="mt-4 mb-1.5 block text-[13px] font-semibold text-ink">Kizárandó (mit kerüljön / ne említsen)</label>
        <textarea x-model="exclude" rows="2" placeholder="Pl. konkrét árak, konkurens biztosítók nevei" class="w-full rounded-xl border border-slate-200 bg-surface px-3.5 py-2.5 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15"></textarea>

        <button type="button" @click="generate()" :disabled="loading" class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl bg-ink py-3 text-[14.5px] font-semibold text-white transition hover:bg-ink/90 disabled:opacity-60">
          <i data-lucide="sparkles" class="h-[18px] w-[18px]" x-show="!loading"></i>
          <svg x-show="loading" class="h-[18px] w-[18px] animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" stroke-opacity="0.3"/><path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          <span x-text="loading ? 'Generálás…' : 'Generálás AI-val'"></span>
        </button>
        <p x-show="error" x-text="error" class="mt-3 rounded-xl border border-danger/20 bg-danger/5 px-3.5 py-2.5 text-[13px] font-medium text-danger"></p>
        <p class="mt-3 text-[12px] text-muted">A generáláshoz az Anthropic API kulcs kell a <a href="/admin/beallitasok" class="font-semibold text-teal hover:underline">Beállításoknál</a>. A generált anyag a jobb oldali szerkesztőbe kerül, ahol szabadon átszerkesztheted.</p>
      </div>
    </div>

    {# Vizuális szerkesztő + mentés #}
    <div class="lg:col-span-3">
      <form method="post" action="/admin/tanacsadas/mentes" @submit="document.getElementById('body-input').value = document.getElementById('veditor').innerHTML">
        <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
        <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
        <input type="hidden" name="id" value="{{ resource.id ?? '' }}">
        <input type="hidden" name="body" id="body-input">

        <div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
          <div class="border-b border-slate-100 p-4">
            <input type="text" name="title" value="{{ resource.title ?? '' }}" required placeholder="Az anyag címe" class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-2.5 text-[15px] font-semibold outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
          </div>

          {# Eszköztár #}
          <div class="flex flex-wrap items-center gap-1 border-b border-slate-100 px-3 py-2">
            <button type="button" @click="exec('bold')" class="rounded-lg px-2.5 py-1.5 text-[13px] font-bold text-ink hover:bg-surface" title="Félkövér">B</button>
            <button type="button" @click="exec('italic')" class="rounded-lg px-2.5 py-1.5 text-[13px] italic text-ink hover:bg-surface" title="Dőlt">I</button>
            <span class="mx-1 h-5 w-px bg-slate-200"></span>
            <button type="button" @click="exec('formatBlock','H2')" class="rounded-lg px-2.5 py-1.5 text-[13px] font-semibold text-ink hover:bg-surface" title="Címsor">H2</button>
            <button type="button" @click="exec('formatBlock','H3')" class="rounded-lg px-2.5 py-1.5 text-[13px] font-semibold text-ink hover:bg-surface" title="Alcím">H3</button>
            <button type="button" @click="exec('formatBlock','P')" class="rounded-lg px-2.5 py-1.5 text-[13px] text-ink hover:bg-surface" title="Bekezdés">¶</button>
            <span class="mx-1 h-5 w-px bg-slate-200"></span>
            <button type="button" @click="exec('insertUnorderedList')" class="flex items-center rounded-lg px-2.5 py-1.5 text-ink hover:bg-surface" title="Lista"><i data-lucide="list" class="h-[16px] w-[16px]"></i></button>
            <button type="button" @click="makeLink()" class="flex items-center rounded-lg px-2.5 py-1.5 text-ink hover:bg-surface" title="Link"><i data-lucide="link" class="h-[16px] w-[16px]"></i></button>
            <button type="button" @click="exec('removeFormat')" class="flex items-center rounded-lg px-2.5 py-1.5 text-muted hover:bg-surface" title="Formázás törlése"><i data-lucide="eraser" class="h-[16px] w-[16px]"></i></button>
          </div>

          {# Szerkeszthető tartalom #}
          <div id="veditor" contenteditable="true" class="min-h-[420px] px-6 py-6 text-[15px] leading-relaxed outline-none">{% if resource %}{{ resource.body|raw }}{% else %}<div style="max-width:760px;margin:0 auto;font-family:Inter,system-ui,sans-serif;color:#1E293B;line-height:1.7;"><p style="color:#64748B;">Itt jelenik meg a generált anyag. Add meg a briefet a bal oldalon, és kattints a „Generálás AI-val" gombra — utána itt szabadon szerkesztheted.</p></div>{% endif %}</div>

          <div class="flex flex-wrap items-center justify-between gap-3 border-t border-slate-100 p-4">
            <label class="flex items-center gap-2 text-[13.5px] font-medium text-ink">
              <input type="checkbox" name="is_published" value="1" {{ (resource and resource.is_published) ? 'checked' : '' }} class="h-4 w-4 rounded border-slate-300 text-teal"> Publikálás (megjelenik az ügyfélportálon)
            </label>
            <div class="flex items-center gap-2">
              <select name="client_id" class="rounded-xl border border-slate-200 bg-surface px-3 py-2 text-[13px] outline-none focus:border-teal">
                <option value="">Mindenkinek</option>
                {% for c in clients %}<option value="{{ c.id }}" {{ (resource and resource.client_id == c.id) ? 'selected' }}>{{ c.name }}</option>{% endfor %}
              </select>
              <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-5 py-2.5 text-[14px] font-semibold text-white transition hover:bg-teal/90"><i data-lucide="save" class="h-[17px] w-[17px]"></i> Mentés</button>
            </div>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function advisoryEditor() {
    return {
      brief: '', tone: 'szakmai', length: 'kozepes', audience: '',
      accent: '{{ resource is defined and resource ? '#0F2A4A' : '#0F2A4A' }}',
      exclude: '', loading: false, error: '',
      csrf: { nameKey: '{{ csrf.keys.name }}', name: '{{ csrf.name }}', valueKey: '{{ csrf.keys.value }}', value: '{{ csrf.value }}' },
      async generate() {
        this.error = '';
        if (!this.brief.trim()) { this.error = 'Add meg, miről generáljon szöveget.'; return; }
        this.loading = true;
        try {
          const body = new URLSearchParams();
          body.set(this.csrf.nameKey, this.csrf.name);
          body.set(this.csrf.valueKey, this.csrf.value);
          body.set('brief', this.brief); body.set('tone', this.tone); body.set('length', this.length);
          body.set('audience', this.audience); body.set('exclude', this.exclude); body.set('accent', this.accent);
          const r = await fetch('/admin/tanacsadas/general', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body });
          const data = await r.json();
          if (!data.ok) { this.error = data.error || 'Hiba a generálás során.'; }
          else { document.getElementById('veditor').innerHTML = data.html; if (window.lucide) window.lucide.createIcons(); }
        } catch (e) { this.error = 'Hálózati hiba: ' + e.message; }
        this.loading = false;
      },
      exec(cmd, val) { document.execCommand(cmd, false, val || null); document.getElementById('veditor').focus(); },
      makeLink() { const url = prompt('Link címe (URL):'); if (url) { document.execCommand('createLink', false, url); } }
    };
  }
</script>
{% endblock %}
