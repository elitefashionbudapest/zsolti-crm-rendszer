{% extends 'layouts/admin.twig' %}
{% block title %}E-mail napló — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6">
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">E-mail napló</h1>
  <p class="mt-1 text-[13.5px] text-muted">{{ list.total }} kiküldési bejegyzés</p>
</div>

<div class="mb-5 flex flex-wrap gap-1 border-b border-slate-200/70">
  {% set tabs = [
    { href: '/admin/email-sablonok', label: 'Sablonok', current: false },
    { href: '/admin/email-folyamatok', label: 'Folyamatok', current: false },
    { href: '/admin/email-naplo', label: 'Napló', current: true },
    { href: '/admin/biztositoi-kuldes', label: 'Biztosítói küldés', current: false }
  ] %}
  {% for t in tabs %}
    <a href="{{ t.href }}" class="border-b-2 px-4 py-2.5 text-[13.5px] font-semibold transition {{ t.current ? 'border-teal text-teal' : 'border-transparent text-muted hover:text-ink' }}">{{ t.label }}</a>
  {% endfor %}
</div>

{% set chip = {
  'sent': 'bg-success/10 text-success',
  'failed': 'bg-danger/10 text-danger',
  'queued': 'bg-amber-100 text-amber-700'
} %}
{% set chipLabel = { 'sent': 'elküldve', 'failed': 'sikertelen', 'queued': 'várakozik' } %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  {% if list.rows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="inbox" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">A napló még üres</p>
      <p class="mt-1 text-[13px] text-muted">Itt jelennek meg a kiküldött levelek.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th class="px-5 py-3 font-semibold">Állapot</th>
            <th class="px-5 py-3 font-semibold">Címzett</th>
            <th class="px-5 py-3 font-semibold">Tárgy</th>
            <th class="px-5 py-3 font-semibold">Elküldve</th>
            <th class="px-5 py-3 font-semibold">Hiba</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for s in list.rows %}
            <tr class="transition hover:bg-surface/60">
              <td data-label="Állapot" class="px-5 py-3.5">
                <span class="rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ chip[s.status] ?? 'bg-slate-100 text-muted' }}">{{ chipLabel[s.status] ?? s.status }}</span>
              </td>
              <td data-label="Címzett" class="px-5 py-3.5 text-ink">{{ s.to_email }}</td>
              <td data-label="Tárgy" class="px-5 py-3.5 text-muted">{{ s.subject ?: '—' }}</td>
              <td data-label="Elküldve" class="px-5 py-3.5 text-muted">{{ s.sent_at ?: '—' }}</td>
              <td data-label="Hiba" class="px-5 py-3.5 text-danger/80 text-[12.5px]">{{ s.error ?: '' }}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if list.pages > 1 %}
      <div class="flex items-center justify-between border-t border-slate-100 px-5 py-3 text-[13px] text-muted">
        <span>{{ list.page }}. oldal / {{ list.pages }}</span>
        <div class="flex gap-2">
          {% if list.page > 1 %}<a href="?page={{ list.page - 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Előző</a>{% endif %}
          {% if list.page < list.pages %}<a href="?page={{ list.page + 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Következő</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
