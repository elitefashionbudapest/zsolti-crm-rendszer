{% extends 'layouts/admin.twig' %}
{% block title %}Dokumentumok — {{ app_name }}{% endblock %}

{% macro filesize(bytes) %}
  {%- set b = bytes|default(0) -%}
  {%- if b >= 1048576 -%}{{ (b / 1048576)|round(1) }} MB
  {%- elseif b >= 1024 -%}{{ (b / 1024)|round(0) }} KB
  {%- else -%}{{ b }} B
  {%- endif -%}
{% endmacro %}
{% import _self as fmt %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Dokumentumok</h1>
    <p class="mt-1 text-[13.5px] text-muted">{{ list.total }} dokumentum az irodában</p>
  </div>
  <a href="/admin/dokumentumok/uj" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
    <i data-lucide="upload" class="h-[18px] w-[18px]"></i> Dokumentum feltöltése
  </a>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border border-danger/20 bg-danger/5 text-danger' : 'border border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  <form method="get" class="flex flex-wrap items-center gap-3 border-b border-slate-100 p-4">
    <div class="relative flex-1 min-w-[200px]">
      <i data-lucide="search" class="pointer-events-none absolute left-3.5 top-1/2 h-[18px] w-[18px] -translate-y-1/2 text-muted"></i>
      <input type="text" name="q" value="{{ search }}" placeholder="Keresés fájlnévre…" class="w-full rounded-xl border border-slate-200 bg-surface py-2.5 pl-11 pr-4 text-[13.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
    </div>
    <select name="client_id" class="rounded-xl border border-slate-200 bg-surface px-3 py-2.5 text-[13.5px] outline-none focus:border-teal">
      <option value="">Minden ügyfél</option>
      {% for c in clients %}
        <option value="{{ c.id }}" {{ clientId == c.id ? 'selected' }}>{{ c.name }}</option>
      {% endfor %}
    </select>
    <button type="submit" class="rounded-xl bg-ink px-4 py-2.5 text-[13.5px] font-semibold text-white transition hover:bg-ink/90">Szűrés</button>
    {% if search or clientId %}<a href="/admin/dokumentumok" class="rounded-xl px-3 py-2.5 text-[13.5px] font-medium text-muted hover:text-ink">Törlés</a>{% endif %}
  </form>

  {% if list.rows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="folder" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs dokumentum</p>
      <p class="mt-1 text-[13px] text-muted">Tölts fel egy dokumentumot, vagy módosítsd a keresést.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th class="px-5 py-3 font-semibold">Fájl</th>
            <th class="px-5 py-3 font-semibold">Ügyfél</th>
            <th class="px-5 py-3 font-semibold">Típus</th>
            <th class="px-5 py-3 font-semibold">Láthatóság</th>
            <th class="px-5 py-3 font-semibold">Méret</th>
            <th class="px-5 py-3 font-semibold">Feltöltve</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for d in list.rows %}
            <tr class="transition hover:bg-surface/60">
              <td class="px-5 py-3.5">
                <div class="flex items-center gap-2.5">
                  <i data-lucide="file" class="h-[18px] w-[18px] shrink-0 text-muted"></i>
                  <span class="font-semibold text-ink">{{ d.original_name }}</span>
                </div>
              </td>
              <td class="px-5 py-3.5 text-muted">{{ d.client_name ?: '—' }}</td>
              <td class="px-5 py-3.5 text-muted">{{ d.type ?: '—' }}</td>
              <td class="px-5 py-3.5">
                {% if d.visibility == 'shared' %}
                  <span class="rounded-full bg-teal/10 px-2.5 py-1 text-[11.5px] font-semibold text-teal">megosztott</span>
                {% else %}
                  <span class="rounded-full bg-slate-100 px-2.5 py-1 text-[11.5px] font-semibold text-muted">csak ügynök</span>
                {% endif %}
              </td>
              <td class="px-5 py-3.5 text-muted">{{ fmt.filesize(d.size_bytes) }}</td>
              <td class="px-5 py-3.5 text-muted">{{ d.created_at ? d.created_at|date('Y-m-d H:i') : '—' }}</td>
              <td class="px-5 py-3.5 text-right">
                <div class="flex items-center justify-end gap-1">
                  <a href="/admin/dokumentumok/{{ d.id }}/letoltes" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-surface hover:text-ink" title="Letöltés"><i data-lucide="download" class="h-4 w-4"></i></a>
                  <form method="post" action="/admin/dokumentumok/{{ d.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a dokumentumot?');">
                    <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                    <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                    <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-danger/5 hover:text-danger" title="Törlés"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if list.pages > 1 %}
      <div class="flex items-center justify-between border-t border-slate-100 px-5 py-3 text-[13px] text-muted">
        <span>{{ list.page }}. oldal / {{ list.pages }}</span>
        <div class="flex gap-2">
          {% if list.page > 1 %}<a href="?q={{ search }}&client_id={{ clientId }}&page={{ list.page - 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Előző</a>{% endif %}
          {% if list.page < list.pages %}<a href="?q={{ search }}&client_id={{ clientId }}&page={{ list.page + 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Következő</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
