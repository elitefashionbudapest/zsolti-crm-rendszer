{% extends 'layouts/admin.twig' %}
{% block title %}{{ mode == 'create' ? 'Új anyag' : 'Anyag szerkesztése' }} — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex items-center gap-3">
  <a href="/admin/tanacsadas" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ mode == 'create' ? 'Új anyag' : 'Anyag szerkesztése' }}</h1>
</div>

<form method="post" action="{{ action }}" class="mx-auto max-w-3xl">
  <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
  <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
    <div>
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Cím</label>
      <input type="text" name="title" value="{{ item.title }}" placeholder="Pl. Mire figyeljen a lakásbiztosításnál?"
        class="w-full rounded-xl border {{ errors.title is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
      {% if errors.title is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.title }}</p>{% endif %}
    </div>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Tartalom</label>
      <textarea name="body" rows="10" placeholder="Az anyag szövege…"
        class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">{{ item.body }}</textarea>
    </div>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Közönség</label>
      <select name="client_id" class="w-full rounded-xl border {{ errors.client_id is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-3 py-2.5 text-[14px] outline-none focus:border-teal">
        <option value="">Mindenki (az iroda összes ügyfele)</option>
        {% for c in clients %}
          <option value="{{ c.id }}" {{ item.client_id == c.id ? 'selected' }}>{{ c.name }}</option>
        {% endfor %}
      </select>
      {% if errors.client_id is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.client_id }}</p>{% endif %}
    </div>

    <div class="mt-5">
      <label class="flex cursor-pointer items-center gap-3">
        <input type="checkbox" name="is_published" value="1" {{ item.is_published ? 'checked' }}
          class="h-4 w-4 rounded border-slate-300 text-teal focus:ring-teal/30">
        <span class="text-[13.5px] font-semibold text-ink">Publikált (látható az ügyfélportálon)</span>
      </label>
    </div>
  </div>

  <div class="mt-5 flex items-center justify-end gap-3">
    <a href="/admin/tanacsadas" class="rounded-xl border border-slate-200 px-5 py-3 text-[14px] font-semibold text-ink transition hover:bg-white">Mégse</a>
    <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white transition hover:bg-teal/90">
      <i data-lucide="save" class="h-[17px] w-[17px]"></i> Mentés
    </button>
  </div>
</form>
{% endblock %}
