{% extends 'layouts/admin.twig' %}
{% block title %}{{ task.title }} — {{ app_name }}{% endblock %}

{% macro row(label, value) %}
  <div class="flex items-center justify-between gap-4 border-b border-slate-100 py-3">
    <span class="text-[13px] text-muted">{{ label }}</span>
    <span class="text-right text-[13.5px] font-semibold text-ink">{{ value ?: '—' }}</span>
  </div>
{% endmacro %}
{% import _self as r %}

{% block main %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/feladatok" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px] {{ task.status == 'done' ? 'line-through text-muted' }}">{{ task.title }}</h1>
      <span class="mt-1 inline-block rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ task.status == 'done' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ task.status == 'done' ? 'kész' : 'nyitott' }}</span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <form method="post" action="/admin/feladatok/{{ task.id }}/kesz">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-success/20 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-success transition hover:bg-success/5"><i data-lucide="{{ task.status == 'done' ? 'rotate-ccw' : 'check' }}" class="h-[17px] w-[17px]"></i> {{ task.status == 'done' ? 'Visszanyitás' : 'Késznek jelölés' }}</button>
    </form>
    <a href="/admin/feladatok/{{ task.id }}/szerkesztes" class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="pencil" class="h-[17px] w-[17px]"></i> Szerkesztés</a>
    <form method="post" action="/admin/feladatok/{{ task.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a feladatot?');">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-danger/20 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-danger transition hover:bg-danger/5"><i data-lucide="trash-2" class="h-[17px] w-[17px]"></i> Törlés</button>
    </form>
  </div>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success"><i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}</div>
{% endif %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
    <h2 class="text-[15px] font-bold text-ink">Adatok</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Partner', task.client_name) }}
      {{ r.row('Határidő', task.due_at ? task.due_at|date('Y-m-d H:i') : null) }}
      {{ r.row('Prioritás', task.priority == 'high' ? 'magas' : (task.priority == 'low' ? 'alacsony' : 'normál')) }}
      {{ r.row('Státusz', task.status == 'done' ? 'kész' : 'nyitott') }}
    </div>
    {% if task.description %}
      <h3 class="mt-6 text-[13px] font-semibold text-ink">Leírás</h3>
      <p class="mt-2 whitespace-pre-line text-[13.5px] leading-relaxed text-muted">{{ task.description }}</p>
    {% endif %}
  </div>

  <div class="space-y-6">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl {{ task.priority == 'high' ? 'bg-danger/10' : (task.priority == 'low' ? 'bg-slate-100' : 'bg-warning/10') }}"><i data-lucide="flag" class="h-[22px] w-[22px] {{ task.priority == 'high' ? 'text-danger' : (task.priority == 'low' ? 'text-muted' : 'text-warning') }}"></i></div>
      <div class="mt-4 text-[18px] font-bold text-ink">{{ task.priority == 'high' ? 'Magas' : (task.priority == 'low' ? 'Alacsony' : 'Normál') }}</div>
      <div class="mt-1 text-[13px] font-medium text-muted">Prioritás</div>
    </div>
  </div>
</div>
{% endblock %}
