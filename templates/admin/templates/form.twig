{% extends 'layouts/admin.twig' %}
{% block title %}{{ mode == 'create' ? 'Új sablon' : 'Sablon szerkesztése' }} — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex items-center gap-3">
  <a href="/admin/sablonok" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ mode == 'create' ? 'Új sablon' : 'Sablon szerkesztése' }}</h1>
</div>

<form method="post" action="{{ action }}" enctype="multipart/form-data" class="mx-auto max-w-3xl"
  x-data="{ kind: '{{ template.kind }}', fileName: '' }">
  <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
  <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
    <h2 class="text-[15px] font-bold text-ink">Sablon adatai</h2>

    <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Név</label>
        <input type="text" name="name" value="{{ template.name }}" placeholder="Pl. Meghatalmazás (PDF)"
          class="w-full rounded-xl border {{ errors.name is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
        {% if errors.name is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.name }}</p>{% endif %}
      </div>
      <div>
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Típus</label>
        <select name="kind" x-model="kind" class="w-full rounded-xl border {{ errors.kind is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-3 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
          <option value="overlay" {{ template.kind == 'overlay' ? 'selected' }}>PDF rátét (lapos PDF-re ír)</option>
          <option value="docx" {{ template.kind == 'docx' ? 'selected' }}>DOCX sablon (${jelölő} csere)</option>
        </select>
        {% if errors.kind is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.kind }}</p>{% endif %}
      </div>
    </div>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">
        Sablonfájl
        {% if mode == 'edit' %}<span class="font-normal text-muted">(csak akkor töltsd fel, ha cserélni szeretnéd)</span>{% endif %}
      </label>
      <label class="flex cursor-pointer flex-col items-center justify-center gap-2 rounded-2xl border-2 border-dashed {{ errors.file is defined ? 'border-danger/50 bg-danger/5' : 'border-slate-200 bg-surface' }} px-6 py-8 text-center transition hover:border-teal hover:bg-teal/5">
        <i data-lucide="upload-cloud" class="h-7 w-7 text-muted"></i>
        <span class="text-[13.5px] font-semibold text-ink" x-text="fileName || (kind === 'docx' ? '.docx fájl feltöltése' : '.pdf fájl feltöltése')"></span>
        <span class="text-[12px] text-muted" x-text="kind === 'docx' ? 'A Word-sablon ${jelölő} markereket tartalmazzon' : 'Lapos, nem titkosított PDF — legfeljebb 20 MB'"></span>
        <input type="file" name="file" class="hidden"
          :accept="kind === 'docx' ? '.docx' : '.pdf'"
          @change="fileName = $event.target.files.length ? $event.target.files[0].name : ''">
      </label>
      {% if errors.file is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.file }}</p>{% endif %}
    </div>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Mezőtérkép (field_map) — JSON</label>
      <textarea name="field_map" rows="8" spellcheck="false"
        class="w-full rounded-xl border {{ errors.field_map is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 font-mono text-[12.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">{{ template.field_map }}</textarea>
      {% if errors.field_map is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.field_map }}</p>{% endif %}

      <div class="mt-3 rounded-xl border border-slate-200 bg-surface/60 p-4 text-[12.5px] leading-relaxed text-muted">
        <p class="mb-2 font-semibold text-ink">Útmutató a két formátumhoz</p>
        <p class="mb-1"><span class="font-semibold text-ink">DOCX:</span> objektum, ahol a kulcs a Word-sablon <code class="rounded bg-white px-1 py-0.5 text-ink">${jelölő}</code> neve, az érték pedig az adatkulcs.</p>
        <pre class="mb-3 overflow-x-auto rounded-lg bg-white p-3 text-[11.5px] text-ink">{"vezeteknev":"client_name","kotvenyszam":"policy_number","datum":"today"}</pre>
        <p class="mb-1"><span class="font-semibold text-ink">PDF rátét:</span> lista, minden elem egy mezőt helyez el. Az <code class="rounded bg-white px-1 py-0.5 text-ink">x</code>/<code class="rounded bg-white px-1 py-0.5 text-ink">y</code> egysége <span class="font-semibold text-ink">pont (pt)</span>, az origó a lap bal felső sarka (1 pt = 1/72 inch, 1 mm ≈ 2,83 pt).</p>
        <pre class="mb-3 overflow-x-auto rounded-lg bg-white p-3 text-[11.5px] text-ink">[{"page":1,"x":120,"y":210,"size":11,"key":"client_name"},
 {"page":1,"x":120,"y":240,"size":11,"key":"policy_number"}]</pre>
        <p class="mb-1 font-semibold text-ink">Elérhető adatkulcsok:</p>
        <p class="font-mono text-[11.5px]">client_name, client_email, client_phone, client_address, tax_id, birth_date, birth_place, mother_name, policy_number, insurer_name, module_name, start_date, end_date, annual_fee, plate, today</p>
      </div>
    </div>

    <div class="mt-5 flex items-center gap-2">
      <input type="checkbox" id="is_active" name="is_active" value="1" {{ template.is_active ? 'checked' }}
        class="h-4 w-4 rounded border-slate-300 text-teal focus:ring-teal/30">
      <label for="is_active" class="text-[13.5px] font-medium text-ink">Aktív sablon</label>
    </div>
  </div>

  <div class="mt-5 flex items-center justify-end gap-3">
    <a href="/admin/sablonok" class="rounded-xl border border-slate-200 px-5 py-3 text-[14px] font-semibold text-ink transition hover:bg-white">Mégse</a>
    <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white transition hover:bg-teal/90">
      <i data-lucide="save" class="h-[17px] w-[17px]"></i> Mentés
    </button>
  </div>
</form>
{% endblock %}
