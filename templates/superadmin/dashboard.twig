{% extends 'layouts/base.twig' %}
{% block title %}Szuperadmin — {{ app_name }}{% endblock %}
{% block robots %}<meta name="robots" content="noindex,nofollow">{% endblock %}

{% block body %}
<div class="min-h-screen bg-surface">
  <header class="sticky top-0 z-40 border-b border-slate-100 bg-white">
    <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8">
      <div class="flex items-center gap-2.5">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-gold"><i data-lucide="crown" class="h-5 w-5 text-ink"></i></div>
        <span class="text-[16px] font-extrabold tracking-tight text-ink">Aegis<span class="text-teal">CRM</span> · Szuperadmin</span>
      </div>
      <form method="post" action="/kilepes">
        <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
        <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
        <button type="submit" class="flex items-center gap-2 rounded-xl border border-slate-200 px-3.5 py-2 text-[13.5px] font-semibold text-danger hover:bg-danger/5"><i data-lucide="log-out" class="h-4 w-4"></i> Kijelentkezés</button>
      </form>
    </div>
  </header>

  <main class="mx-auto max-w-6xl px-5 py-8 sm:px-8">
    <h1 class="text-[24px] font-bold tracking-tight text-ink">Szuperadmin vezérlőpult</h1>
    <p class="mt-1 text-[14px] text-muted">Irodák, dolgozók és előfizetések kezelése.</p>
    <div class="mt-7 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-ink/5"><i data-lucide="building-2" class="h-[22px] w-[22px] text-ink"></i></div>
        <div class="mt-4 text-[30px] font-extrabold text-ink">{{ offices }}</div>
        <div class="mt-1 text-[13px] font-medium text-muted">Irodák</div>
      </div>
      <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal/10"><i data-lucide="users" class="h-[22px] w-[22px] text-teal"></i></div>
        <div class="mt-4 text-[30px] font-extrabold text-ink">{{ users }}</div>
        <div class="mt-1 text-[13px] font-medium text-muted">Felhasználók</div>
      </div>
      <div class="rounded-2xl border border-dashed border-slate-300 bg-white/50 p-6">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-surface"><i data-lucide="plus" class="h-[22px] w-[22px] text-muted"></i></div>
        <div class="mt-4 text-[14px] font-semibold text-ink">Új iroda</div>
        <div class="mt-1 text-[12.5px] text-muted">A kezelőfelület a következő fázisban készül el.</div>
      </div>
    </div>
  </main>
</div>
{% endblock %}
