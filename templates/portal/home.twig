{% extends 'layouts/portal.twig' %}
{% block title %}Kezdő — Ügyfélportál{% endblock %}

{% set category_icons = {
  'elet_egeszseg': 'heart-pulse',
  'vagyon': 'home',
  'nyugdij_megtakaritas': 'piggy-bank',
  'befektetes': 'trending-up'
} %}

{% block main %}
<h1 class="text-[26px] font-extrabold tracking-tight text-ink sm:text-[30px]">Üdv, {{ first_name }}! 👋</h1>
<p class="mt-1.5 text-[15px] text-muted">Itt egy helyen látja szerződéseit, a közelgő határidőket és ügynökét.</p>

<div class="mt-7 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft">
    <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-ink/5"><i data-lucide="calendar-heart" class="h-[22px] w-[22px] text-ink"></i></div>
    <div class="mt-4 text-[13px] font-semibold text-muted">Következő évforduló</div>
    {% if next_anniversary %}
      <div class="mt-1 text-[20px] font-extrabold text-ink">{{ next_anniversary.date }}</div>
      <div class="mt-1 text-[12.5px] text-muted">{{ next_anniversary.label }} · {{ next_anniversary.days }} nap múlva</div>
    {% else %}
      <div class="mt-1 text-[20px] font-extrabold text-ink">—</div>
      <div class="mt-1 text-[12.5px] text-muted">Nincs közelgő évforduló</div>
    {% endif %}
  </div>
  <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft">
    <div class="flex items-start justify-between">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-warning/10"><i data-lucide="clock-alert" class="h-[22px] w-[22px] text-warning"></i></div>
      {% if next_expiry and next_expiry.days <= 30 %}
        <span class="rounded-full bg-warning/10 px-2.5 py-1 text-[11.5px] font-semibold text-warning">hamarosan lejár</span>
      {% endif %}
    </div>
    <div class="mt-4 text-[13px] font-semibold text-muted">Közelgő lejárat</div>
    {% if next_expiry %}
      <div class="mt-1 text-[20px] font-extrabold text-ink">{{ next_expiry.date }}</div>
      <div class="mt-1 text-[12.5px] text-muted">{{ next_expiry.label }} · {{ next_expiry.days }} nap múlva</div>
    {% else %}
      <div class="mt-1 text-[20px] font-extrabold text-ink">—</div>
      <div class="mt-1 text-[12.5px] text-muted">Nincs közelgő lejárat</div>
    {% endif %}
  </div>
  <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft sm:col-span-2 lg:col-span-1">
    <div class="text-[13px] font-semibold text-muted">Ügynököm</div>
    <div class="mt-3 flex items-center gap-3.5">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-ink to-teal text-[18px] font-bold text-white">Ü</div>
      <div class="leading-tight"><div class="text-[15.5px] font-bold text-ink">Ügynök</div><div class="text-[12.5px] text-muted">Tanácsadó</div></div>
    </div>
    <a href="/portal/uzenetek" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-teal py-3 text-[14px] font-semibold text-white transition hover:bg-teal/90"><i data-lucide="message-circle" class="h-[18px] w-[18px]"></i> Kapcsolatfelvétel</a>
  </div>
</div>

<div class="mt-5 rounded-2xl border border-slate-200/70 bg-white shadow-soft">
  <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
    <div class="flex items-center gap-2.5"><i data-lucide="file-text" class="h-5 w-5 text-teal"></i><h2 class="text-[15px] font-bold text-ink">Szerződéseim</h2></div>
    {% if contract_count > 0 %}
      <a href="/portal/szerzodeseim" class="text-[13px] font-semibold text-teal hover:underline">Összes</a>
    {% endif %}
  </div>
  {% if contracts is empty %}
    <div class="px-5 py-10 text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-surface"><i data-lucide="file-text" class="h-6 w-6 text-muted"></i></div>
      <p class="mt-3 text-[13.5px] text-muted">Még nincs megjeleníthető szerződése. Kérdés esetén keresse ügynökét.</p>
    </div>
  {% else %}
    <ul class="divide-y divide-slate-100">
      {% for c in contracts %}
        <li class="flex items-center gap-4 px-5 py-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-surface"><i data-lucide="{{ category_icons[c.category]|default('file-text') }}" class="h-5 w-5 text-ink"></i></div>
          <div class="min-w-0 flex-1">
            <div class="truncate text-[14.5px] font-semibold text-ink">{{ c.module_name ?: c.insurer_name ?: 'Szerződés' }}</div>
            <div class="text-[12.5px] text-muted">
              {%- if c.policy_number %}Kötvényszám: {{ c.policy_number }}{% endif -%}
              {%- if c.anniversary %} · évforduló: {{ c.anniversary }}{% endif -%}
            </div>
          </div>
          <span class="shrink-0 rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ c.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ c.status == 'active' ? 'aktív' : 'megszűnt' }}</span>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
{% endblock %}
