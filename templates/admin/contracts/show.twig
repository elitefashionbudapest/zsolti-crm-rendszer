{% extends 'layouts/admin.twig' %}
{% block title %}{{ contract.policy_number ?: contract.module_name ?: 'Szerződés' }} — {{ app_name }}{% endblock %}

{% macro row(label, value) %}
  <div class="flex items-center justify-between gap-4 border-b border-slate-100 py-3">
    <span class="text-[13px] text-muted">{{ label }}</span>
    <span class="text-right text-[13.5px] font-semibold text-ink">{{ value ?: '—' }}</span>
  </div>
{% endmacro %}
{% import _self as r %}

{% block main %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/szerzodesek" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ contract.module_name ?: contract.policy_number ?: 'Szerződés' }}</h1>
      <span class="mt-1 inline-block rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ contract.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ contract.status == 'active' ? 'élő' : 'megszűnt' }}</span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/admin/szerzodesek/{{ contract.id }}/szerkesztes" class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="pencil" class="h-[17px] w-[17px]"></i> Szerkesztés</a>
    <form method="post" action="/admin/szerzodesek/{{ contract.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a szerződést?');">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-danger/20 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-danger transition hover:bg-danger/5"><i data-lucide="trash-2" class="h-[17px] w-[17px]"></i> Törlés</button>
    </form>
  </div>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success"><i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}</div>
{% endif %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
    <h2 class="text-[15px] font-bold text-ink">Alapadatok</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Ügyfél', contract.client_name) }}
      {{ r.row('Kategória', categories[contract.category]|default(contract.category)) }}
      {{ r.row('Biztosító', contract.insurer_name) }}
      {{ r.row('Módozat kódja', contract.module_code) }}
      {{ r.row('Módozat neve', contract.module_name) }}
      {{ r.row('Rendszám', contract.plate) }}
    </div>

    <h2 class="mt-7 text-[15px] font-bold text-ink">Kötvény</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Kötvényszám', contract.policy_number) }}
      {{ r.row('Ajánlatszám', contract.offer_number) }}
      {{ r.row('Kezdet', contract.start_date) }}
      {{ r.row('Lejárat', contract.end_date) }}
      {{ r.row('Évforduló', contract.anniversary) }}
      {{ r.row('Éves díj', contract.annual_fee) }}
      {{ r.row('Kockázatviselés helye', contract.risk_location) }}
    </div>

    <h2 class="mt-7 text-[15px] font-bold text-ink">Díjfizetés és ügynök</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Fizetési gyakoriság', contract.payment_frequency) }}
      {{ r.row('Fizetési mód', contract.payment_method) }}
      {{ r.row('Ügynök kódja', contract.agent_code) }}
      {{ r.row('Ügynök neve', contract.agent_name) }}
      {{ r.row('Megszűnés oka', contract.terminated_reason) }}
    </div>
  </div>

  <div class="space-y-6">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal/10"><i data-lucide="user" class="h-[22px] w-[22px] text-teal"></i></div>
      <div class="mt-4 text-[15px] font-bold text-ink">{{ contract.client_name ?: '—' }}</div>
      <div class="mt-1 text-[13px] font-medium text-muted">Szerződő ügyfél</div>
      {% if contract.client_id %}
        <a href="/admin/partnerek/{{ contract.client_id }}" class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-teal hover:text-teal/80">Partner megnyitása <i data-lucide="arrow-right" class="h-4 w-4"></i></a>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
