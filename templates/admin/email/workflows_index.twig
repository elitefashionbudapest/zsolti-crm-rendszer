{% extends 'layouts/admin.twig' %}
{% block title %}E-mail folyamatok — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">E-mail folyamatok</h1>
    <p class="mt-1 text-[13.5px] text-muted">Automatizmusok és kézi kiküldés</p>
  </div>
  <a href="/admin/email-folyamatok/uj" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
    <i data-lucide="plus" class="h-[18px] w-[18px]"></i> Új folyamat
  </a>
</div>

<div class="mb-5 flex flex-wrap gap-1 border-b border-slate-200/70">
  {% set tabs = [
    { href: '/admin/email-sablonok', label: 'Sablonok', current: false },
    { href: '/admin/email-folyamatok', label: 'Folyamatok', current: true },
    { href: '/admin/email-naplo', label: 'Napló', current: false },
    { href: '/admin/biztositoi-kuldes', label: 'Biztosítói küldés', current: false }
  ] %}
  {% for t in tabs %}
    <a href="{{ t.href }}" class="border-b-2 px-4 py-2.5 text-[13.5px] font-semibold transition {{ t.current ? 'border-teal text-teal' : 'border-transparent text-muted hover:text-ink' }}">{{ t.label }}</a>
  {% endfor %}
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  {% if workflows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="workflow" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Még nincs folyamat</p>
      <p class="mt-1 text-[13px] text-muted">Hozz létre egy folyamatot egy sablonhoz kötve.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th class="px-5 py-3 font-semibold">Név</th>
            <th class="px-5 py-3 font-semibold">Trigger</th>
            <th class="px-5 py-3 font-semibold">Sablon</th>
            <th class="px-5 py-3 font-semibold">Állapot</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for w in workflows %}
            <tr class="transition hover:bg-surface/60">
              <td data-label="Név" class="px-5 py-3.5"><a href="/admin/email-folyamatok/{{ w.id }}/szerkesztes" class="font-semibold text-ink hover:text-teal">{{ w.name }}</a></td>
              <td data-label="Trigger" class="px-5 py-3.5 text-muted">
                {{ triggerTypes[w.trigger_type] ?? w.trigger_type }}
                {% if w.trigger_days is not null %}<span class="text-[12px]">({{ w.trigger_days }} nap)</span>{% endif %}
              </td>
              <td data-label="Sablon" class="px-5 py-3.5 text-muted">{{ w.template_id and templates[w.template_id] ? templates[w.template_id].name : '—' }}</td>
              <td data-label="Állapot" class="px-5 py-3.5">
                <span class="rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ w.is_active ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ w.is_active ? 'aktív' : 'inaktív' }}</span>
              </td>
              <td class="px-5 py-3.5 text-right">
                <div class="flex items-center justify-end gap-1">
                  {% if w.trigger_type == 'manual' %}
                    <form method="post" action="/admin/email-folyamatok/{{ w.id }}/futtatas" onsubmit="return confirm('Biztosan elküldöd most ezt a folyamatot minden e-mail címmel rendelkező ügyfélnek?');">
                      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                      <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-ink px-3 py-1.5 text-[12.5px] font-semibold text-white transition hover:bg-ink/90"><i data-lucide="send" class="h-3.5 w-3.5"></i> Futtatás most</button>
                    </form>
                  {% endif %}
                  <a aria-label="Szerkesztés" href="/admin/email-folyamatok/{{ w.id }}/szerkesztes" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-surface hover:text-ink"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                  <form method="post" action="/admin/email-folyamatok/{{ w.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a folyamatot?');">
                    <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                    <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                    <button aria-label="Törlés" type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-danger/5 hover:text-danger"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
