{% extends 'layouts/admin.twig' %}
{% block title %}{{ insurer.name }} — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/biztositok" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ insurer.name }}</h1>
      <span class="mt-1 inline-block rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ insurer.is_active ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ insurer.is_active ? 'aktív' : 'inaktív' }}</span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/admin/biztositok/{{ insurer.id }}/szerkesztes" class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="pencil" class="h-[17px] w-[17px]"></i> Szerkesztés</a>
    <form method="post" action="/admin/biztositok/{{ insurer.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a biztosítót?');">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-danger/20 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-danger transition hover:bg-danger/5"><i data-lucide="trash-2" class="h-[17px] w-[17px]"></i> Törlés</button>
    </form>
  </div>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 space-y-6">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <h2 class="text-[15px] font-bold text-ink">E-mail címlisták</h2>
      <p class="mt-1 text-[13px] text-muted">A kategóriához tartozó címlista felülírja az alapértelmezett címeket a küldéskor.</p>

      {% if routes is empty %}
        <div class="mt-5 rounded-xl border border-dashed border-slate-200 bg-surface/50 px-5 py-8 text-center">
          <p class="text-[13.5px] font-medium text-ink">Még nincs egyedi címlista</p>
          <p class="mt-1 text-[13px] text-muted">A küldés az alapértelmezett címekre megy, amíg nem adsz hozzá kategória szerinti listát.</p>
        </div>
      {% else %}
        <div class="mt-5 overflow-x-auto">
          <table class="w-full text-left text-[13.5px]">
            <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
              <tr>
                <th class="px-3 py-3 font-semibold">Kategória</th>
                <th class="px-3 py-3 font-semibold">Címek</th>
                <th class="px-3 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {% for route in routes %}
                <tr class="align-top">
                  <td class="px-3 py-3.5 font-semibold text-ink">{{ route.category ? categoryLabels[route.category]|default(route.category) : 'Alapértelmezett (minden típus)' }}</td>
                  <td class="px-3 py-3.5 whitespace-pre-line text-muted">{{ route.emails }}</td>
                  <td class="px-3 py-3.5 text-right">
                    <form method="post" action="/admin/biztositok/{{ insurer.id }}/cimlista/{{ route.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a címlistát?');">
                      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                      <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-danger/5 hover:text-danger"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>

    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <h2 class="text-[15px] font-bold text-ink">Új címlista</h2>
      <form method="post" action="/admin/biztositok/{{ insurer.id }}/cimlista" class="mt-5">
        <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
        <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="sm:col-span-1">
            <label class="mb-1.5 block text-[13px] font-semibold text-ink">Kategória</label>
            <select name="category" class="w-full rounded-xl border border-slate-200 bg-surface px-3 py-3 text-[14px] outline-none focus:border-teal">
              <option value="">Alapértelmezett (minden típus)</option>
              {% for code in categories %}
                <option value="{{ code }}">{{ categoryLabels[code]|default(code) }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="sm:col-span-2">
            <label class="mb-1.5 block text-[13px] font-semibold text-ink">E-mail címek</label>
            <textarea name="emails" rows="3" placeholder="kar@biztosito.hu&#10;ugyfelszolgalat@biztosito.hu"
              class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15"></textarea>
            <p class="mt-1.5 text-[12px] text-muted">Soronként vagy vesszővel elválasztva.</p>
          </div>
        </div>

        <div class="mt-5 flex justify-end">
          <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-5 py-2.5 text-[13.5px] font-semibold text-white transition hover:bg-teal/90">
            <i data-lucide="plus" class="h-[17px] w-[17px]"></i> Címlista hozzáadása
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="space-y-6">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <h2 class="text-[15px] font-bold text-ink">Alapértelmezett címek</h2>
      {% if insurer.default_emails %}
        <p class="mt-3 whitespace-pre-line text-[13.5px] leading-relaxed text-muted">{{ insurer.default_emails }}</p>
      {% else %}
        <p class="mt-3 text-[13px] text-muted">Nincs alapértelmezett cím megadva.</p>
      {% endif %}
      <p class="mt-4 text-[12.5px] text-muted">Ezekre a címekre megy a küldés, ha az adott típushoz nincs külön címlista.</p>
    </div>
  </div>
</div>
{% endblock %}
