{% extends 'layouts/admin.twig' %}
{% block title %}Dokumentumsablonok — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Dokumentumsablonok</h1>
    <p class="mt-1 text-[13.5px] text-muted">{{ templates|length }} sablon az irodában</p>
  </div>
  <a href="/admin/sablonok/uj" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
    <i data-lucide="plus" class="h-[18px] w-[18px]"></i> Új sablon
  </a>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium
    {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  {% if templates is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="file-stack" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs sablon</p>
      <p class="mt-1 text-[13px] text-muted">Hozz létre egy PDF rátét- vagy DOCX-sablont a kitöltéshez.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th class="px-5 py-3 font-semibold">Név</th>
            <th class="px-5 py-3 font-semibold">Típus</th>
            <th class="px-5 py-3 font-semibold">Állapot</th>
            <th class="px-5 py-3 text-right">Műveletek</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for t in templates %}
            <tr class="transition hover:bg-surface/60">
              <td class="px-5 py-3.5 font-semibold text-ink">{{ t.name }}</td>
              <td class="px-5 py-3.5">
                {% if t.kind == 'docx' %}
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-blue-50 px-2.5 py-1 text-[11.5px] font-semibold text-blue-700"><i data-lucide="file-text" class="h-3.5 w-3.5"></i> DOCX</span>
                {% else %}
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-50 px-2.5 py-1 text-[11.5px] font-semibold text-amber-700"><i data-lucide="file-type-2" class="h-3.5 w-3.5"></i> PDF rátét</span>
                {% endif %}
              </td>
              <td class="px-5 py-3.5">
                <span class="rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ t.is_active ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ t.is_active ? 'aktív' : 'inaktív' }}</span>
              </td>
              <td class="px-5 py-3.5">
                <div class="flex items-center justify-end gap-1.5">
                  <a href="/admin/sablonok/{{ t.id }}/kitoltes" class="inline-flex items-center gap-1.5 rounded-lg bg-teal/10 px-3 py-1.5 text-[12.5px] font-semibold text-teal transition hover:bg-teal/15">
                    <i data-lucide="wand-2" class="h-4 w-4"></i> Kitöltés
                  </a>
                  <a href="/admin/sablonok/{{ t.id }}/szerkesztes" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-surface hover:text-ink"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                  <form method="post" action="/admin/sablonok/{{ t.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a sablont?');" class="inline">
                    <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                    <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                    <button type="submit" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-danger/5 hover:text-danger"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                  </form>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% endif %}
</div>
{% endblock %}
