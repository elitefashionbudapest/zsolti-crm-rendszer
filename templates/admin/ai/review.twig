{% extends 'layouts/admin.twig' %}
{% block title %}Kinyert adatok ellenőrzése — {{ app_name }}{% endblock %}

{% macro field(label, name, fields, type, placeholder) %}
  <div>
    <label class="mb-1.5 block text-[13px] font-semibold text-ink">{{ label }}</label>
    <input type="{{ type|default('text') }}" name="{{ name }}" value="{{ fields[name] }}" placeholder="{{ placeholder|default('') }}"
      class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
  </div>
{% endmacro %}
{% import _self as f %}

{% block main %}
<div class="mb-6 flex items-center gap-3">
  <a href="/admin/ai-kinyeres" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Kinyert adatok ellenőrzése</h1>
    <p class="mt-0.5 text-[13px] text-muted">Modell: {{ extraction.model ?: '—' }} • {{ extraction.created_at }}</p>
  </div>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

{% if extraction.status == 'processing' %}
  <meta http-equiv="refresh" content="5">
  <div class="rounded-2xl border border-slate-200/70 bg-white p-12 text-center shadow-card">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-teal/10"><i data-lucide="loader-2" class="h-7 w-7 animate-spin text-teal"></i></div>
    <p class="mt-4 text-[15px] font-semibold text-ink">Feldolgozás alatt…</p>
    <p class="mt-1.5 text-[13.5px] text-muted">Az AI éppen kiolvassa az adatokat a dokumentumból. Az oldal 5 másodpercenként automatikusan frissül.</p>
    <a href="/admin/ai-kinyeres/{{ extraction.id }}" class="mt-5 inline-flex items-center gap-1.5 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="refresh-cw" class="h-4 w-4"></i> Frissítés most</a>
  </div>
{% elseif extraction.status == 'failed' %}
  <div class="rounded-2xl border border-danger/20 bg-white p-10 text-center shadow-card">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-danger/10"><i data-lucide="alert-triangle" class="h-7 w-7 text-danger"></i></div>
    <p class="mt-4 text-[15px] font-semibold text-ink">A feldolgozás nem sikerült</p>
    <p class="mt-1.5 text-[13.5px] text-muted">{{ errorMsg ?: 'Ismeretlen hiba történt a kinyerés közben.' }}</p>
    <a href="/admin/ai-kinyeres" class="mt-5 inline-flex items-center gap-1.5 rounded-xl bg-ink px-4 py-2.5 text-[13.5px] font-semibold text-white transition hover:bg-ink/90"><i data-lucide="upload" class="h-4 w-4"></i> Új dokumentum feltöltése</a>
  </div>
{% else %}
<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-1">
    <div class="rounded-2xl border border-teal/20 bg-teal/5 p-6 shadow-card">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal/15 text-teal"><i data-lucide="shield-check" class="h-5 w-5"></i></div>
        <h2 class="text-[15px] font-bold text-ink">Ellenőrzés</h2>
      </div>
      <p class="mt-4 text-[13.5px] leading-relaxed text-ink/80">Ellenőrizd és javítsd a kinyert adatokat a jóváhagyás előtt. A jóváhagyás létrehoz egy partnert, és ha van szerződésre vonatkozó adat, egy szerződést is.</p>
    </div>
  </div>

  <div class="lg:col-span-2">
    {% if duplicate %}
      <div class="mb-4 rounded-xl border border-warning/30 bg-warning/5 px-4 py-3.5 text-[13.5px] text-ink">
        <div class="flex items-start gap-2">
          <i data-lucide="alert-triangle" class="mt-0.5 h-4 w-4 shrink-0 text-warning"></i>
          <div>
            <p class="font-semibold">Már létezik egy partner ezekkel az azonosító adatokkal:
              <a href="/admin/partnerek/{{ duplicate.id }}" class="underline">{{ duplicate.name }}</a>.</p>
            <p class="mt-1 text-muted">Ha a „Felülírás" jelölővel hagyod jóvá, a meglévő partner adatai és attribútumai felülíródnak a kinyert adatokkal. Enélkül új partner NEM jön létre.</p>
          </div>
        </div>
      </div>
    {% endif %}

    <form method="post" action="/admin/ai-kinyeres/{{ extraction.id }}/jovahagyas"
      x-data="{{ { 'extra': extra }|json_encode|e('html_attr') }}">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

      <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
        <h2 class="text-[15px] font-bold text-ink">Ügyféladatok</h2>
        <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {{ f.field('Név', 'client_name', fields, 'text', 'Pl. Kovács Anna') }}
          {{ f.field('E-mail', 'client_email', fields, 'email', 'nev@email.hu') }}
          {{ f.field('Telefon', 'client_phone', fields) }}
          {{ f.field('Mobil', 'client_mobile', fields) }}
          <div class="sm:col-span-2">{{ f.field('Cím', 'client_address', fields) }}</div>
          {{ f.field('Adóazonosító jel', 'tax_id', fields) }}
          {{ f.field('Születési dátum (ÉÉÉÉ-HH-NN)', 'birth_date', fields, 'text', '1990-05-12') }}
          {{ f.field('Születési hely', 'birth_place', fields) }}
          {{ f.field('Anyja neve', 'mother_name', fields) }}
        </div>

        <h2 class="mt-7 text-[15px] font-bold text-ink">Szerződésadatok</h2>
        <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {{ f.field('Ágazat / kategória', 'category', fields) }}
          {{ f.field('Biztosító', 'insurer_name', fields) }}
          {{ f.field('Módozat kódja', 'module_code', fields) }}
          {{ f.field('Módozat', 'module_name', fields) }}
          {{ f.field('Kötvényszám', 'policy_number', fields) }}
          {{ f.field('Ajánlatszám', 'offer_number', fields) }}
          {{ f.field('Kezdő dátum (ÉÉÉÉ-HH-NN)', 'start_date', fields, 'text', '2026-01-01') }}
          {{ f.field('Lejárat (ÉÉÉÉ-HH-NN)', 'end_date', fields, 'text', '2027-01-01') }}
          {{ f.field('Évforduló', 'anniversary', fields) }}
          {{ f.field('Éves díj', 'annual_fee', fields) }}
          {{ f.field('Díjfizetés gyakorisága', 'payment_frequency', fields) }}
          {{ f.field('Díjfizetés módja', 'payment_method', fields) }}
          {{ f.field('Közvetítő kódja', 'agent_code', fields) }}
          {{ f.field('Közvetítő neve', 'agent_name', fields) }}
          {{ f.field('Kockázatviselés helye', 'risk_location', fields) }}
          {{ f.field('Rendszám', 'plate', fields) }}
        </div>
      </div>

      {# További kinyert adatok — címezhető attribútumok (szerkeszthető/törölhető) #}
      <div class="mt-5 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-[15px] font-bold text-ink">További kinyert adatok</h2>
            <p class="mt-0.5 text-[12.5px] text-muted">Minden itt megmaradó sor külön, névvel elmentődik a partnerhez (később másik dokumentum kitöltésére is használható).</p>
          </div>
          <button type="button" @click="extra.push({group:'egyeb', attr_key:'', label:'', value:''})"
            class="flex shrink-0 items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-[12.5px] font-semibold text-ink transition hover:bg-surface">
            <i data-lucide="plus" class="h-[15px] w-[15px]"></i> Új mező
          </button>
        </div>

        <template x-if="extra.length === 0">
          <p class="mt-5 text-[13px] text-muted">Nincs további kinyert adat.</p>
        </template>

        <div class="mt-5 space-y-3">
          <template x-for="(row, i) in extra" :key="i">
            <div class="grid grid-cols-1 gap-2 sm:grid-cols-[1fr_1.4fr_auto] sm:items-center">
              <input type="text" x-model="row.label"
                :name="`extra[${i}][label]`" placeholder="Megnevezés"
                @input="if(!row.attr_key){row._auto=true}; if(row._auto){row.attr_key = row.label.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/[^a-z0-9]+/g,'_').replace(/^_+|_+$/g,'')}"
                class="w-full rounded-xl border border-slate-200 bg-surface px-3.5 py-2.5 text-[13.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
              <input type="text" x-model="row.value"
                :name="`extra[${i}][value]`" placeholder="Érték"
                class="w-full rounded-xl border border-slate-200 bg-surface px-3.5 py-2.5 text-[13.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
              <div class="flex items-center gap-2">
                <input type="hidden" :name="`extra[${i}][attr_key]`" :value="row.attr_key">
                <input type="hidden" :name="`extra[${i}][group]`" :value="row.group || 'egyeb'">
                <span class="hidden rounded-md bg-surface px-2 py-1 text-[11px] font-medium text-muted sm:inline" x-text="row.group || 'egyeb'"></span>
                <button type="button" @click="extra.splice(i,1)" aria-label="Törlés"
                  class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-muted transition hover:bg-danger/5 hover:text-danger">
                  <i data-lucide="trash-2" class="h-4 w-4"></i>
                </button>
              </div>
            </div>
          </template>
        </div>
      </div>

      <div class="mt-5 flex items-center justify-end gap-3">
        {% if duplicate %}
          <label class="flex items-center gap-2 text-[13.5px] font-semibold text-ink">
            <input type="checkbox" name="overwrite" value="1" required class="h-4 w-4 rounded border-slate-300 text-teal focus:ring-teal/30">
            Felülírás megerősítése
          </label>
        {% endif %}
        <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
          <i data-lucide="check" class="h-[17px] w-[17px]"></i> {{ duplicate ? 'Felülírás és mentés' : 'Jóváhagyás és mentés' }}
        </button>
      </div>
    </form>

    <form method="post" action="/admin/ai-kinyeres/{{ extraction.id }}/elvetes" class="mt-3 flex justify-end"
      onsubmit="return confirm('Biztosan elveted a kinyert adatokat?');">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-danger/30 px-5 py-2.5 text-[13.5px] font-semibold text-danger transition hover:bg-danger/5">
        <i data-lucide="trash-2" class="h-[16px] w-[16px]"></i> Elvetés
      </button>
    </form>
  </div>
</div>
{% endif %}
{% endblock %}
