{% extends 'layouts/admin.twig' %}
{% block title %}Ügyféltáblázat — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-5 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Ügyféltáblázat</h1>
    <p class="mt-1 text-[13.5px] text-muted">{{ total }} sor · az Excel (Munkafüzet1) szerinti, lapos nézet — szerződésenként egy sor</p>
  </div>
  <a href="/admin/import" class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13px] font-semibold text-ink shadow-soft transition hover:bg-surface"><i data-lucide="upload" class="h-[17px] w-[17px]"></i> Excel import</a>
</div>

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  <form method="get" class="flex flex-wrap items-center gap-2.5 border-b border-slate-100 p-3.5">
    <div class="relative min-w-[220px] flex-1">
      <i data-lucide="search" class="pointer-events-none absolute left-3 top-1/2 h-[16px] w-[16px] -translate-y-1/2 text-muted"></i>
      <input type="text" name="q" value="{{ search }}" placeholder="Keresés: ügyfél, kötvényszám, biztosító, módozat, e-mail…" class="w-full rounded-lg border border-slate-200 bg-surface py-2 pl-9 pr-3 text-[13px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
    </div>
    <select name="category" class="rounded-lg border border-slate-200 bg-surface px-2.5 py-2 text-[13px] outline-none focus:border-teal">
      <option value="">Minden típus</option>
      {% for code, label in categories %}<option value="{{ code }}" {{ category == code ? 'selected' }}>{{ label }}</option>{% endfor %}
    </select>
    <select name="status" class="rounded-lg border border-slate-200 bg-surface px-2.5 py-2 text-[13px] outline-none focus:border-teal">
      <option value="">Minden státusz</option>
      <option value="active" {{ status == 'active' ? 'selected' }}>Aktív</option>
      <option value="terminated" {{ status == 'terminated' ? 'selected' }}>Megszűnt</option>
    </select>
    <button type="submit" class="rounded-lg bg-ink px-3.5 py-2 text-[13px] font-semibold text-white transition hover:bg-ink/90">Szűrés</button>
    {% if search or category or status %}<a href="/admin/ugyfel-tablazat" class="rounded-lg px-2.5 py-2 text-[13px] font-medium text-muted hover:text-ink">Törlés</a>{% endif %}
  </form>

  {% if rows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="table" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs adat</p>
      <p class="mt-1 text-[13px] text-muted">Importáld a meglévő Excel-t, vagy rögzíts szerződéseket.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead class="border-b border-slate-100 uppercase tracking-wide text-muted">
          <tr>
            <th class="font-semibold">Típus</th>
            <th class="font-semibold">Biztosító</th>
            <th class="font-semibold">Módozat neve</th>
            <th class="font-semibold">Ügyfél neve</th>
            <th class="font-semibold">Telefon</th>
            <th class="font-semibold">E-mail</th>
            <th class="font-semibold">Kötvényszám</th>
            <th class="font-semibold">Kezdet</th>
            <th class="font-semibold">Vége</th>
            <th class="font-semibold">Évf.</th>
            <th class="font-semibold text-right">Éves díj</th>
            <th class="font-semibold">Díjfiz.</th>
            <th class="font-semibold">Üzletkötő</th>
            <th class="font-semibold">Státusz</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for r in rows %}
            <tr class="transition hover:bg-surface/60">
              <td class="text-muted">{{ categories[r.category]|default('—') }}</td>
              <td class="font-medium text-ink">{{ r.insurer_name ?: '—' }}</td>
              <td class="text-ink">{{ r.module_name ?: '—' }}</td>
              <td class="font-semibold text-ink">{% if r.client_id %}<a href="/admin/partnerek/{{ r.client_id }}" class="hover:text-teal">{{ r.client_name ?: '—' }}</a>{% else %}{{ r.client_name ?: '—' }}{% endif %}</td>
              <td class="text-muted">{{ r.client_mobile ?: r.client_phone ?: '—' }}</td>
              <td class="text-muted">{{ r.client_email ?: '—' }}</td>
              <td class="text-muted">{{ r.policy_number ?: '—' }}</td>
              <td class="text-muted">{{ r.start_date ?: '—' }}</td>
              <td class="text-muted">{{ r.end_date ?: '—' }}</td>
              <td class="text-muted">{{ r.anniversary ?: '—' }}</td>
              <td class="text-right font-medium text-ink">{% if r.annual_fee %}{{ r.annual_fee|number_format(0, ',', ' ') }} Ft{% else %}—{% endif %}</td>
              <td class="text-muted">{{ r.payment_frequency ?: '—' }}</td>
              <td class="text-muted">{{ r.agent_name ?: '—' }}</td>
              <td><span class="rounded-full px-2 py-0.5 text-[11px] font-semibold {{ r.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ r.status == 'active' ? 'aktív' : (r.status == 'terminated' ? 'megszűnt' : (r.status ?: '—')) }}</span></td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if pages > 1 %}
      <div class="flex items-center justify-between border-t border-slate-100 px-4 py-3 text-[12.5px] text-muted">
        <span>{{ page }}. / {{ pages }} oldal</span>
        <div class="flex gap-2">
          {% if page > 1 %}<a href="?q={{ search }}&category={{ category }}&status={{ status }}&page={{ page - 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Előző</a>{% endif %}
          {% if page < pages %}<a href="?q={{ search }}&category={{ category }}&status={{ status }}&page={{ page + 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Következő</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
