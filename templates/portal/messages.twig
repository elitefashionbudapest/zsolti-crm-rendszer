{% extends 'layouts/portal.twig' %}
{% block title %}Üzenetek — Ügyfélportál{% endblock %}

{% block main %}
<h1 class="text-[26px] font-extrabold tracking-tight text-ink sm:text-[30px]">Üzenetek</h1>
<p class="mt-1.5 text-[15px] text-muted">Írjon közvetlenül ügynökének, és hamarosan felveszi Önnel a kapcsolatot.</p>

{% if flash %}
  <div class="mt-5 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success"><i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}</div>
{% endif %}

<div class="mt-6 grid grid-cols-1 gap-5 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft sm:p-6">
    <form method="post" action="/portal/uzenetek">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Üzenet</label>
      <textarea name="message" rows="5" required placeholder="Írja ide üzenetét…" class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15"></textarea>
      <div class="mt-4 flex justify-end">
        <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white transition hover:bg-teal/90">
          <i data-lucide="send" class="h-[17px] w-[17px]"></i> Küldés
        </button>
      </div>
    </form>
  </div>

  <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft sm:p-6">
    <div class="text-[13px] font-semibold text-muted">Ügynököd</div>
    <div class="mt-3 flex items-center gap-3.5">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-ink to-teal text-[18px] font-bold text-white">{{ agent_name|slice(0,1)|upper }}</div>
      <div class="leading-tight">
        <div class="text-[15.5px] font-bold text-ink">{{ agent_name }}</div>
        <div class="text-[12.5px] text-muted">Tanácsadó</div>
      </div>
    </div>
    <p class="mt-4 text-[12.5px] leading-relaxed text-muted">Üzenete feladatként eljut ügynökéhez, aki munkanapokon belül válaszol.</p>
  </div>
</div>

<div class="mt-5 rounded-2xl border border-slate-200/70 bg-white shadow-soft">
  <div class="flex items-center gap-2.5 border-b border-slate-100 px-5 py-4"><i data-lucide="message-circle" class="h-5 w-5 text-teal"></i><h2 class="text-[15px] font-bold text-ink">Korábbi üzeneteim</h2></div>
  {% if messages is empty %}
    <div class="px-5 py-10 text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-surface"><i data-lucide="inbox" class="h-6 w-6 text-muted"></i></div>
      <p class="mt-3 text-[13.5px] text-muted">Még nem küldött üzenetet.</p>
    </div>
  {% else %}
    <ul class="divide-y divide-slate-100">
      {% for m in messages %}
        <li class="px-5 py-4">
          <p class="text-[14px] text-ink whitespace-pre-line">{{ m.description }}</p>
          {% if m.created_at %}<div class="mt-1 text-[12px] text-muted">{{ m.created_at }}</div>{% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
{% endblock %}
