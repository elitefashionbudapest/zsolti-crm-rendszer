{% extends 'layouts/admin.twig' %}
{% block title %}{{ contract.policy_number ?: contract.module_name ?: 'Szerződés' }} — {{ app_name }}{% endblock %}

{% macro row(label, value) %}
  <div class="flex items-center justify-between gap-4 border-b border-slate-100 py-3">
    <span class="text-[13px] text-muted">{{ label }}</span>
    <span class="text-right text-[13.5px] font-semibold text-ink">{{ value ?: '—' }}</span>
  </div>
{% endmacro %}
{% import _self as r %}

{% block main %}
<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <div class="flex items-center gap-3">
    <a href="/admin/szerzodesek" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
    <div>
      <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ contract.module_name ?: contract.policy_number ?: 'Szerződés' }}</h1>
      <span class="mt-1 inline-block rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ contract.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ contract.status == 'active' ? 'élő' : 'megszűnt' }}</span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <a href="/admin/szerzodesek/{{ contract.id }}/szerkesztes" class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="pencil" class="h-[17px] w-[17px]"></i> Szerkesztés</a>
    <form method="post" action="/admin/szerzodesek/{{ contract.id }}/torles" onsubmit="return confirm('Biztosan törlöd ezt a szerződést?');">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl border border-danger/20 bg-white px-4 py-2.5 text-[13.5px] font-semibold text-danger transition hover:bg-danger/5"><i data-lucide="trash-2" class="h-[17px] w-[17px]"></i> Törlés</button>
    </form>
  </div>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success"><i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}</div>
{% endif %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
    <h2 class="text-[15px] font-bold text-ink">Alapadatok</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Ügyfél', contract.client_name) }}
      {{ r.row('Kategória', categories[contract.category]|default(contract.category)) }}
      {{ r.row('Biztosító', contract.insurer_name) }}
      {{ r.row('Módozat kódja', contract.module_code) }}
      {{ r.row('Módozat neve', contract.module_name) }}
      {{ r.row('Rendszám', contract.plate) }}
    </div>

    <h2 class="mt-7 text-[15px] font-bold text-ink">Kötvény</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Kötvényszám', contract.policy_number) }}
      {{ r.row('Ajánlatszám', contract.offer_number) }}
      {{ r.row('Kezdet', contract.start_date) }}
      {{ r.row('Lejárat', contract.end_date) }}
      {{ r.row('Évforduló', contract.anniversary) }}
      {{ r.row('Éves díj', contract.annual_fee) }}
      {{ r.row('Kockázatviselés helye', contract.risk_location) }}
    </div>

    <h2 class="mt-7 text-[15px] font-bold text-ink">Díjfizetés és ügynök</h2>
    <div class="mt-4 grid grid-cols-1 gap-x-8 sm:grid-cols-2">
      {{ r.row('Fizetési gyakoriság', contract.payment_frequency) }}
      {{ r.row('Fizetési mód', contract.payment_method) }}
      {{ r.row('Ügynök kódja', contract.agent_code) }}
      {{ r.row('Ügynök neve', contract.agent_name) }}
      {{ r.row('Megszűnés oka', contract.terminated_reason) }}
    </div>
  </div>

  <div class="space-y-6">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal/10"><i data-lucide="user" class="h-[22px] w-[22px] text-teal"></i></div>
      <div class="mt-4 text-[15px] font-bold text-ink">{{ contract.client_name ?: '—' }}</div>
      <div class="mt-1 text-[13px] font-medium text-muted">Szerződő ügyfél</div>
      {% if contract.client_id %}
        <a href="/admin/partnerek/{{ contract.client_id }}" class="mt-3 inline-flex items-center gap-1.5 text-[13px] font-semibold text-teal hover:text-teal/80">Partner megnyitása <i data-lucide="arrow-right" class="h-4 w-4"></i></a>
      {% endif %}
    </div>
  </div>
</div>

{# Kinyert / egyéb adatok — a szerződéshez kötött címezhető attribútumok #}
{% set groupLabels = {
  'szerzodo': 'Szerződő',
  'biztositott_1': '1. biztosított',
  'biztositott_2': '2. biztosított',
  'kedvezmenyezett': 'Kedvezményezett',
  'bank': 'Bank / fizetés',
  'szerzodes': 'Szerződés',
  'egyeb': 'Egyéb'
} %}
<div id="attributumok" class="mt-6 rounded-2xl border border-slate-200/70 bg-white shadow-card">
  <div class="flex items-center gap-2.5 border-b border-slate-100 px-5 py-4">
    <i data-lucide="database" class="h-[19px] w-[19px] text-teal"></i>
    <h2 class="text-[15px] font-bold text-ink">Kinyert és egyéb adatok</h2>
    <span class="rounded-full bg-surface px-2 py-0.5 text-[11.5px] font-medium text-muted">sablonokhoz is felhasználható</span>
  </div>
  <div class="p-5">
    {% if attributes is empty %}
      <p class="text-[13px] text-muted">Nincs kinyert adat ehhez a szerződéshez. Az AI-kinyerés jóváhagyásakor kerülnek ide, vagy adj hozzá kézzel lent.</p>
    {% else %}
      <div class="space-y-6">
        {% for group, rows in attributes %}
          <div>
            <h3 class="mb-2 text-[12px] font-bold uppercase tracking-wide text-muted">{{ groupLabels[group] ?? group }}</h3>
            <div class="divide-y divide-slate-100">
              {% for a in rows %}
                <form method="post" action="/admin/szerzodesek/{{ contract.id }}/attributumok/{{ a.id }}/frissites"
                  class="flex flex-wrap items-center gap-2 py-2 sm:flex-nowrap">
                  <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                  <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                  <input type="text" name="label" value="{{ a.label }}"
                    class="w-full rounded-lg border border-slate-200 bg-surface px-3 py-2 text-[13px] font-medium text-ink outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15 sm:w-[38%]">
                  <input type="text" name="value" value="{{ a.value }}"
                    class="w-full flex-1 rounded-lg border border-slate-200 bg-surface px-3 py-2 text-[13px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
                  <code class="hidden shrink-0 rounded bg-surface px-1.5 py-1 text-[11px] text-muted md:inline">${{ '{' }}{{ a.attr_key }}{{ '}' }}</code>
                  <button type="submit" aria-label="Mentés" title="Mentés"
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-muted transition hover:bg-teal/5 hover:text-teal"><i data-lucide="check" class="h-4 w-4"></i></button>
                  <button type="submit" formaction="/admin/szerzodesek/{{ contract.id }}/attributumok/{{ a.id }}/torles"
                    formnovalidate onclick="return confirm('Törlöd ezt az adatot?');" aria-label="Törlés" title="Törlés"
                    class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg text-muted transition hover:bg-danger/5 hover:text-danger"><i data-lucide="trash-2" class="h-4 w-4"></i></button>
                </form>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# Új attribútum hozzáadása #}
    <form method="post" action="/admin/szerzodesek/{{ contract.id }}/attributumok" class="mt-5 flex flex-wrap items-end gap-2 border-t border-slate-100 pt-4 sm:flex-nowrap">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <div class="w-full sm:w-[30%]">
        <label class="mb-1 block text-[11.5px] font-semibold text-muted">Csoport</label>
        <select name="group" class="w-full rounded-lg border border-slate-200 bg-surface px-3 py-2 text-[13px] outline-none focus:border-teal focus:bg-white">
          {% for code, lbl in groupLabels %}<option value="{{ code }}">{{ lbl }}</option>{% endfor %}
        </select>
      </div>
      <div class="w-full sm:w-[30%]">
        <label class="mb-1 block text-[11.5px] font-semibold text-muted">Megnevezés</label>
        <input type="text" name="label" required placeholder="Pl. IBAN" class="w-full rounded-lg border border-slate-200 bg-surface px-3 py-2 text-[13px] outline-none focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
      </div>
      <div class="w-full flex-1">
        <label class="mb-1 block text-[11.5px] font-semibold text-muted">Érték</label>
        <input type="text" name="value" required placeholder="Érték" class="w-full rounded-lg border border-slate-200 bg-surface px-3 py-2 text-[13px] outline-none focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
      </div>
      <button type="submit" class="flex shrink-0 items-center gap-1.5 rounded-lg bg-teal px-4 py-2 text-[13px] font-semibold text-white transition hover:bg-teal/90"><i data-lucide="plus" class="h-[15px] w-[15px]"></i> Hozzáadás</button>
    </form>
  </div>
</div>
{% endblock %}
