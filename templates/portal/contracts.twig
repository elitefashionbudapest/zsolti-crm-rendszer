{% extends 'layouts/portal.twig' %}
{% block title %}Szerződéseim — Ügyfélportál{% endblock %}

{% set category_icons = {
  'elet_egeszseg': 'heart-pulse',
  'vagyon': 'home',
  'nyugdij_megtakaritas': 'piggy-bank',
  'befektetes': 'trending-up'
} %}

{% block main %}
<h1 class="text-[26px] font-bold tracking-tight text-ink sm:text-[30px]">Szerződéseim</h1>
<p class="mt-1.5 text-[15px] text-muted">Itt áttekintheti az összes biztosítási szerződését.</p>

{% if contracts is empty %}
  <div class="mt-7 flex min-h-[40vh] flex-col items-center justify-center rounded-2xl border border-slate-200/70 bg-white p-8 text-center shadow-soft">
    <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-surface"><i data-lucide="file-text" class="h-8 w-8 text-muted"></i></div>
    <h2 class="mt-5 text-[18px] font-bold text-ink">Még nincs szerződése</h2>
    <p class="mt-2 max-w-sm text-[14.5px] text-muted">Amint új szerződés kerül a rendszerbe, itt fog megjelenni. Kérdés esetén keresse ügynökét.</p>
  </div>
{% else %}
  <div class="mt-7 grid grid-cols-1 gap-4 sm:grid-cols-2">
    {% for c in contracts %}
      <div class="rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft">
        <div class="flex items-start justify-between gap-3">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-surface"><i data-lucide="{{ category_icons[c.category]|default('file-text') }}" class="h-[22px] w-[22px] text-ink"></i></div>
          <span class="shrink-0 rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ c.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ c.status == 'active' ? 'aktív' : 'megszűnt' }}</span>
        </div>
        <div class="mt-4 text-[15.5px] font-bold text-ink">{{ c.module_name ?: c.insurer_name ?: 'Szerződés' }}</div>
        <div class="mt-0.5 text-[13px] text-muted">{{ categories[c.category]|default(c.category) }}</div>

        <dl class="mt-4 space-y-2 border-t border-slate-100 pt-4 text-[13px]">
          {% if c.insurer_name %}
            <div class="flex items-center justify-between gap-4"><dt class="text-muted">Biztosító</dt><dd class="text-right font-semibold text-ink">{{ c.insurer_name }}</dd></div>
          {% endif %}
          {% if c.policy_number %}
            <div class="flex items-center justify-between gap-4"><dt class="text-muted">Kötvényszám</dt><dd class="text-right font-semibold text-ink">{{ c.policy_number }}</dd></div>
          {% endif %}
          {% if c.anniversary %}
            <div class="flex items-center justify-between gap-4"><dt class="text-muted">Évforduló</dt><dd class="text-right font-semibold text-ink">{{ c.anniversary }}</dd></div>
          {% endif %}
          {% if c.end_date %}
            <div class="flex items-center justify-between gap-4"><dt class="text-muted">Lejárat</dt><dd class="text-right font-semibold text-ink">{{ c.end_date }}</dd></div>
          {% endif %}
        </dl>
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
