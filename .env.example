# Alkalmazás
APP_NAME="AegisCRM"
APP_ENV=production
APP_DEBUG=false
# A Gmail OAuth redirect URI ebből + /admin/beallitasok/gmail/callback áll össze.
# Alkönyvtáras telepítésnél a teljes bázis kell, pl. https://visualbyadam.hu/zsolti_crm
APP_URL=https://app.example.hu
APP_TIMEZONE=Europe/Budapest
# Alkönyvtáras telepítéshez add meg az előtagot (pl. /zsolti_crm). Gyökérnél hagyd üresen.
BASE_PATH=

# Titkosítási kulcs (generálás: php bin/console app:generate-key)
# Defuse\Crypto kulcs hex formátumban — KÖTELEZŐ, soha ne kerüljön gitbe.
APP_KEY=

# Adatbázis — éles: mysql. Helyi fejlesztéshez: sqlite.
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=aegis_crm
DB_USER=aegis
DB_PASS=
DB_CHARSET=utf8mb4
# SQLite esetén: DB_DRIVER=sqlite és DB_DATABASE az alábbi útvonal
DB_DATABASE=storage/database.sqlite

# Munkamenet (session)
SESSION_NAME=aegis_session
SESSION_LIFETIME=7200
# Éles: kötelezően true (HTTPS mögött)
SESSION_SECURE=true

# Naplózás
LOG_LEVEL=warning

# Claude (Anthropic) API — irodánként is felülírható a beállításokban
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
