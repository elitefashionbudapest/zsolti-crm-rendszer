{
    "name": "aegis/crm",
    "description": "CRM biztosítási ügynököknek és pénzügyi tanácsadóknak (Slim 4 + Twig)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "defuse/php-encryption": "^2.4",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "php-di/php-di": "^7.0",
        "phpoffice/phpspreadsheet": "^5.8",
        "phpoffice/phpword": "^1.4",
        "ramsey/uuid": "^4.7",
        "respect/validation": "^2.3",
        "robmorgan/phinx": "^0.16",
        "robthree/twofactorauth": "^3.0",
        "setasign/fpdf": "^1.9",
        "setasign/fpdi": "^2.6",
        "slim/csrf": "^1.5",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "slim/twig-view": "^3.3",
        "symfony/console": "^6.4",
        "symfony/mailer": "^6.4 || ^7.0",
        "twig/twig": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "webklex/php-imap": "^6.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "phinx migrate -c phinx.php",
        "rollback": "phinx rollback -c phinx.php",
        "seed": "phinx seed:run -c phinx.php",
        "test": "phpunit",
        "stan": "phpstan analyse",
        "serve": "php -S localhost:8080 -t public"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "sort-packages": true,
        "platform": {
            "php": "8.3.31"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
