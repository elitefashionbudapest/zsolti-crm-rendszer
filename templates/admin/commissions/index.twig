{% extends 'layouts/admin.twig' %}
{% block title %}Jutalékok — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Jutalékok</h1>
    <p class="mt-1 text-[13.5px] text-muted">{{ list.total }} jutalék az irodában</p>
  </div>
  <a href="/admin/jutalekok/uj" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
    <i data-lucide="plus" class="h-[18px] w-[18px]"></i> Új jutalék
  </a>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success">
    <i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
    <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-warning/10"><i data-lucide="hourglass" class="h-[22px] w-[22px] text-warning"></i></div>
    <div class="mt-4 text-[30px] font-bold text-ink">{{ totals.pending|number_format(0, ',', ' ') }} Ft</div>
    <div class="mt-1 text-[13px] font-medium text-muted">Függő összeg</div>
  </div>
  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
    <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-success/10"><i data-lucide="check-circle-2" class="h-[22px] w-[22px] text-success"></i></div>
    <div class="mt-4 text-[30px] font-bold text-ink">{{ totals.settled|number_format(0, ',', ' ') }} Ft</div>
    <div class="mt-1 text-[13px] font-medium text-muted">Rendezett összeg</div>
  </div>
</div>

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  <form method="get" class="flex flex-wrap items-center gap-3 border-b border-slate-100 p-4">
    <select name="status" class="rounded-xl border border-slate-200 bg-surface px-3 py-2.5 text-[13.5px] outline-none focus:border-teal">
      <option value="">Minden státusz</option>
      <option value="pending" {{ status == 'pending' ? 'selected' }}>Függő</option>
      <option value="settled" {{ status == 'settled' ? 'selected' }}>Rendezett</option>
    </select>
    <button type="submit" class="rounded-xl bg-ink px-4 py-2.5 text-[13.5px] font-semibold text-white transition hover:bg-ink/90">Szűrés</button>
    {% if status %}<a href="/admin/jutalekok" class="rounded-xl px-3 py-2.5 text-[13.5px] font-medium text-muted hover:text-ink">Törlés</a>{% endif %}
  </form>

  {% if list.rows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="coins" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs találat</p>
      <p class="mt-1 text-[13px] text-muted">Rögzíts egy új jutalékot, vagy módosítsd a szűrést.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th scope="col" class="px-5 py-3 font-semibold">Szerződés</th>
            <th scope="col" class="num px-5 py-3 font-semibold">Összeg</th>
            <th scope="col" class="px-5 py-3 font-semibold">Státusz</th>
            <th scope="col" class="px-5 py-3 font-semibold">Rendezve</th>
            <th scope="col" class="px-5 py-3"><span class="sr-only">Műveletek</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for c in list.rows %}
            <tr class="transition hover:bg-surface/60">
              <td data-label="Szerződés" class="px-5 py-3.5 font-semibold text-ink">{{ c.contract_label ?: '—' }}</td>
              <td data-label="Összeg" class="num px-5 py-3.5 text-ink">{{ c.amount is not null ? (c.amount|number_format(0, ',', ' ') ~ ' Ft') : '—' }}</td>
              <td data-label="Státusz" class="px-5 py-3.5">
                {% if c.status == 'settled' %}
                  <span class="rounded-full bg-success/10 px-2.5 py-1 text-[11.5px] font-semibold text-success">rendezett</span>
                {% else %}
                  <span class="rounded-full bg-warning/10 px-2.5 py-1 text-[11.5px] font-semibold text-warning">függő</span>
                {% endif %}
              </td>
              <td data-label="Rendezve" class="px-5 py-3.5 text-muted">{{ c.settled_at ?: '—' }}</td>
              <td data-label="Műveletek" class="px-5 py-3.5 text-right">
                <div class="flex items-center justify-end gap-2">
                  {% if c.status != 'settled' %}
                    <form method="post" action="/admin/jutalekok/{{ c.id }}/rendezes">
                      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                      <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg border border-success/20 bg-white px-3 py-1.5 text-[12.5px] font-semibold text-success transition hover:bg-success/5"><i data-lucide="check" class="h-4 w-4"></i> Rendezés</button>
                    </form>
                  {% endif %}
                  <a aria-label="Szerkesztés" href="/admin/jutalekok/{{ c.id }}/szerkesztes" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-surface hover:text-ink"><i data-lucide="pencil" class="h-4 w-4"></i></a>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if list.pages > 1 %}
      <div class="flex items-center justify-between border-t border-slate-100 px-5 py-3 text-[13px] text-muted">
        <span>{{ list.page }}. oldal / {{ list.pages }}</span>
        <div class="flex gap-2">
          {% if list.page > 1 %}<a href="?status={{ status }}&page={{ list.page - 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Előző</a>{% endif %}
          {% if list.page < list.pages %}<a href="?status={{ status }}&page={{ list.page + 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Következő</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
