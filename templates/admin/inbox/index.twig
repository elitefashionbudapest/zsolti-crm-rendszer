{% extends 'layouts/admin.twig' %}
{% block title %}Postaláda — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Postaláda</h1>
    <p class="mt-1 text-[13.5px] text-muted">Beérkező e-mailek az iroda postafiókjából — kattints egy levélre az elolvasáshoz</p>
  </div>
  {% if configured %}
    <form method="post" action="/admin/postalada/szinkron">
      <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
      <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
      <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90"><i data-lucide="refresh-cw" class="h-[18px] w-[18px]"></i> Szinkronizálás most</button>
    </form>
  {% endif %}
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

{% if not configured %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-warning/20 bg-warning/5 px-4 py-3 text-[13.5px] font-medium text-warning">
    <i data-lucide="info" class="h-4 w-4"></i> Az IMAP-fiók nincs beállítva. Állítsd be a <a href="/admin/beallitasok" class="font-semibold underline">Beállításoknál</a>.
  </div>
{% endif %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  {% if emails is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="inbox" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs beérkező levél</p>
      <p class="mt-1 text-[13px] text-muted">Kösd be az IMAP-fiókot és szinkronizálj.</p>
    </div>
  {% else %}
    <ul class="divide-y divide-slate-100">
      {% for m in emails %}
        <li x-data="{ open: false }">
          <button type="button" @click="open = !open" :aria-expanded="open" class="flex w-full items-start gap-4 px-5 py-4 text-left transition hover:bg-surface/60">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-surface"><i data-lucide="mail" class="h-5 w-5 text-ink"></i></div>
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2">
                <span class="truncate text-[14px] font-semibold text-ink">{{ m.subject ?: '(nincs tárgy)' }}</span>
                {% if m.category %}<span class="rounded-full bg-teal/10 px-2 py-0.5 text-[11px] font-semibold text-teal">{{ m.category }}</span>{% endif %}
              </div>
              <div class="mt-0.5 text-[12.5px] text-muted">{{ m.from_email }}</div>
              {% if m.body %}<p x-show="!open" class="mt-1 line-clamp-2 text-[12.5px] text-muted">{{ m.body|slice(0, 160) }}</p>{% endif %}
            </div>
            <div class="flex shrink-0 items-center gap-2 text-[12px] text-muted">
              <span>{{ m.received_at }}</span>
              <i data-lucide="chevron-down" class="h-4 w-4 transition-transform" :class="open ? 'rotate-180' : ''"></i>
            </div>
          </button>
          <div x-show="open" x-cloak class="border-t border-slate-100 bg-surface/40 px-5 py-4 sm:pl-[76px]">
            {# Partnerhez rendelés #}
            <form method="post" action="/admin/postalada/{{ m.id }}/partner" class="mb-4 flex flex-wrap items-center gap-2">
              <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
              <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
              <span class="text-[12.5px] font-semibold text-muted">Partner:</span>
              <select name="client_id" class="rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-[13px] outline-none focus:border-teal">
                <option value="0">— nincs —</option>
                {% for c in clients %}<option value="{{ c.id }}" {{ m.client_id == c.id ? 'selected' }}>{{ c.name }}</option>{% endfor %}
              </select>
              <button type="submit" class="rounded-lg bg-ink px-3 py-1.5 text-[12.5px] font-semibold text-white transition hover:bg-ink/90">Hozzárendelés</button>
              {% if m.client_name %}<span class="inline-flex items-center gap-1 text-[12px] font-semibold text-success"><i data-lucide="user-check" class="h-3.5 w-3.5"></i> {{ m.client_name }}</span>{% endif %}
            </form>

            {# Törzs: HTML (sandbox-iframe) vagy sima szöveg #}
            {% if m.body_html %}
              <iframe sandbox="allow-same-origin" srcdoc="{{ m.body_html|e('html_attr') }}" title="E-mail tartalom" class="w-full rounded-lg border border-slate-200 bg-white" style="height: min(60vh, 600px);"></iframe>
            {% elseif m.body %}
              <div class="whitespace-pre-wrap break-words text-[13.5px] leading-relaxed text-body">{{ m.body }}</div>
            {% else %}
              <p class="text-[13px] italic text-muted">Ehhez a levélhez nincs elmentett szövegtörzs.</p>
            {% endif %}

            {# Mellékletek #}
            {% set atts = attachments[m.id] ?? [] %}
            {% if atts is not empty %}
              <div class="mt-4">
                <div class="mb-2 text-[12.5px] font-semibold text-ink">Mellékletek ({{ atts|length }})</div>
                <div class="space-y-2">
                  {% for a in atts %}
                    <div class="flex items-center gap-3 rounded-xl border border-slate-200 bg-white px-3 py-2.5">
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-surface"><i data-lucide="paperclip" class="h-4 w-4 text-ink"></i></div>
                      <div class="min-w-0 flex-1"><div class="truncate text-[13px] font-semibold text-ink">{{ a.filename }}</div><div class="text-[11px] text-muted">{{ (a.size_bytes / 1024)|round }} KB · {{ a.mime }}</div></div>
                      {% if a.saved_document_id %}
                        <span class="inline-flex shrink-0 items-center gap-1 rounded-full bg-success/10 px-2.5 py-1 text-[11.5px] font-semibold text-success"><i data-lucide="check" class="h-3.5 w-3.5"></i> Mentve</span>
                      {% else %}
                        <form method="post" action="/admin/postalada/melleklet/{{ a.id }}/mentes" class="shrink-0">
                          <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
                          <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
                          <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-[12.5px] font-semibold text-ink transition hover:bg-surface"><i data-lucide="save" class="h-4 w-4 text-teal"></i> Mentés a partnerhez</button>
                        </form>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          </div>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
</div>
{% endblock %}
