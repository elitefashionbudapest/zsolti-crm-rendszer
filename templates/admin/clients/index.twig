{% extends 'layouts/admin.twig' %}
{% block title %}Partnerek — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">Partnerek</h1>
    <p class="mt-1 text-[13.5px] text-muted">{{ list.total }} partner az irodában</p>
  </div>
  <a href="/admin/partnerek/uj" class="flex items-center gap-2 rounded-xl bg-teal px-4 py-2.5 text-[13.5px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
    <i data-lucide="plus" class="h-[18px] w-[18px]"></i> Új partner
  </a>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border border-success/20 bg-success/5 px-4 py-3 text-[13.5px] font-medium text-success">
    <i data-lucide="check-circle-2" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
  <form method="get" class="flex flex-wrap items-center gap-3 border-b border-slate-100 p-4">
    <div class="relative flex-1 min-w-[200px]">
      <i data-lucide="search" class="pointer-events-none absolute left-3.5 top-1/2 h-[18px] w-[18px] -translate-y-1/2 text-muted"></i>
      <input type="text" name="q" value="{{ search }}" placeholder="Keresés név, e-mail, telefon…" class="w-full rounded-xl border border-slate-200 bg-surface py-2.5 pl-11 pr-4 text-[13.5px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
    </div>
    <select name="status" class="rounded-xl border border-slate-200 bg-surface px-3 py-2.5 text-[13.5px] outline-none focus:border-teal">
      <option value="">Minden státusz</option>
      <option value="active" {{ status == 'active' ? 'selected' }}>Aktív</option>
      <option value="inactive" {{ status == 'inactive' ? 'selected' }}>Inaktív</option>
    </select>
    <button type="submit" class="rounded-xl bg-ink px-4 py-2.5 text-[13.5px] font-semibold text-white transition hover:bg-ink/90">Szűrés</button>
    {% if search or status %}<a href="/admin/partnerek" class="rounded-xl px-3 py-2.5 text-[13.5px] font-medium text-muted hover:text-ink">Törlés</a>{% endif %}
  </form>

  {% if list.rows is empty %}
    <div class="px-5 py-16 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="users" class="h-7 w-7 text-muted"></i></div>
      <p class="mt-4 text-[14px] font-medium text-ink">Nincs találat</p>
      <p class="mt-1 text-[13px] text-muted">Hozz létre egy új partnert, vagy módosítsd a keresést.</p>
    </div>
  {% else %}
    <div class="overflow-x-auto">
      <table class="w-full text-left text-[13.5px]">
        <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
          <tr>
            <th scope="col" class="px-5 py-3 font-semibold">Név</th>
            <th scope="col" class="px-5 py-3 font-semibold">E-mail</th>
            <th scope="col" class="px-5 py-3 font-semibold">Telefon</th>
            <th scope="col" class="px-5 py-3 font-semibold">Státusz</th>
            <th scope="col" class="px-5 py-3"><span class="sr-only">Műveletek</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          {% for c in list.rows %}
            <tr class="transition hover:bg-surface/60">
              <td data-label="Név" class="px-5 py-3.5"><a href="/admin/partnerek/{{ c.id }}" class="font-semibold text-ink hover:text-teal">{{ c.name }}</a></td>
              <td data-label="E-mail" class="px-5 py-3.5 text-muted">{{ c.email ?: '—' }}</td>
              <td data-label="Telefon" class="px-5 py-3.5 text-muted">{{ c.mobile ?: c.phone ?: '—' }}</td>
              <td data-label="Státusz" class="px-5 py-3.5">
                <span class="rounded-full px-2.5 py-1 text-[11.5px] font-semibold {{ c.status == 'active' ? 'bg-success/10 text-success' : 'bg-slate-100 text-muted' }}">{{ c.status == 'active' ? 'aktív' : 'inaktív' }}</span>
              </td>
              <td data-label="Műveletek" class="px-5 py-3.5 text-right">
                <a href="/admin/partnerek/{{ c.id }}/szerkesztes" aria-label="{{ c.name }} szerkesztése" class="inline-flex h-8 w-8 items-center justify-center rounded-lg text-muted hover:bg-surface hover:text-ink"><i data-lucide="pencil" class="h-4 w-4"></i></a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if list.pages > 1 %}
      <div class="flex items-center justify-between border-t border-slate-100 px-5 py-3 text-[13px] text-muted">
        <span>{{ list.page }}. oldal / {{ list.pages }}</span>
        <div class="flex gap-2">
          {% if list.page > 1 %}<a href="?q={{ search }}&status={{ status }}&page={{ list.page - 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Előző</a>{% endif %}
          {% if list.page < list.pages %}<a href="?q={{ search }}&status={{ status }}&page={{ list.page + 1 }}" class="rounded-lg border border-slate-200 px-3 py-1.5 font-medium hover:bg-surface">Következő</a>{% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>
{% endblock %}
