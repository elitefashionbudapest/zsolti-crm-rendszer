{% extends 'layouts/base.twig' %}
{% block robots %}<meta name="robots" content="noindex,nofollow">{% endblock %}

{% set nav = [
  { id: 'home', label: 'Kezdő', short: 'Kezdő', icon: 'home', href: '/portal' },
  { id: 'contracts', label: 'Szerződéseim', short: 'Szerződés', icon: 'file-text', href: '/portal/szerzodeseim' },
  { id: 'documents', label: 'Dokumentumaim', short: 'Dokumentum', icon: 'folder', href: '/portal/dokumentumaim' },
  { id: 'data', label: 'Adataim', short: 'Adataim', icon: 'id-card', href: '/portal/adataim' },
  { id: 'messages', label: 'Üzenetek', short: 'Üzenet', icon: 'message-circle', href: '/portal/uzenetek' }
] %}

{% block body %}
<div class="min-h-screen bg-surface">
  <header class="sticky top-0 z-40 border-b border-slate-100 bg-white">
    <div class="flex h-16 items-center justify-between px-5 sm:px-7">
      <div class="flex items-center gap-2.5">
        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-ink"><i data-lucide="shield-check" class="h-5 w-5 text-teal"></i></div>
        <div class="leading-tight"><div class="text-[15px] font-extrabold tracking-tight text-ink">Biztosító Iroda</div><div class="text-[11px] font-medium text-muted">Ügyfélportál</div></div>
      </div>
      <div x-data="{ open: false }" class="relative flex items-center gap-3">
        <span class="hidden text-[13.5px] font-semibold text-ink sm:block">{{ current_user.name }}</span>
        <button @click="open = !open" class="flex h-10 w-10 items-center justify-center rounded-full bg-ink text-[14px] font-bold text-white">{{ current_user.name|slice(0,2)|upper }}</button>
        <div x-show="open" @click.outside="open = false" x-cloak class="absolute right-0 top-12 w-44 rounded-xl border border-slate-200 bg-white p-1.5 shadow-card">
          <form method="post" action="/kilepes">
            <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
            <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">
            <button type="submit" class="flex w-full items-center gap-2 rounded-lg px-3 py-2 text-left text-[13.5px] font-medium text-danger hover:bg-danger/5"><i data-lucide="log-out" class="h-4 w-4"></i> Kijelentkezés</button>
          </form>
        </div>
      </div>
    </div>
  </header>

  <aside class="fixed bottom-0 left-0 top-16 z-30 hidden w-60 flex-col border-r border-slate-100 bg-white px-4 py-6 lg:flex">
    <nav class="flex flex-col gap-1.5">
      {% for n in nav %}
        <a href="{{ n.href }}" class="flex items-center gap-3 rounded-xl px-3.5 py-3 text-[14.5px] font-semibold transition {{ active == n.id ? 'bg-ink text-white shadow-soft' : 'text-muted hover:bg-surface hover:text-ink' }}">
          <i data-lucide="{{ n.icon }}" class="h-5 w-5 shrink-0"></i>{{ n.label }}
        </a>
      {% endfor %}
    </nav>
  </aside>

  <main class="px-5 pb-28 pt-6 sm:px-7 lg:pb-10 lg:pl-[272px] lg:pr-8">
    <div class="mx-auto w-full max-w-4xl">{% block main %}{% endblock %}</div>
  </main>

  <nav class="fixed inset-x-0 bottom-0 z-40 border-t border-slate-100 bg-white pb-[env(safe-area-inset-bottom)] lg:hidden">
    <div class="grid grid-cols-5">
      {% for n in nav %}
        <a href="{{ n.href }}" class="flex flex-col items-center gap-1 py-2.5 transition {{ active == n.id ? 'text-teal' : 'text-muted' }}">
          <i data-lucide="{{ n.icon }}" class="h-[22px] w-[22px]"></i><span class="text-[10.5px] font-semibold">{{ n.short }}</span>
        </a>
      {% endfor %}
    </div>
  </nav>
</div>
{% endblock %}
