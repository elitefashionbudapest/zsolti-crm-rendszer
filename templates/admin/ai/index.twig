{% extends 'layouts/admin.twig' %}
{% block title %}AI adatkinyerés — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6">
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">AI adatkinyerés</h1>
  <p class="mt-1 text-[13.5px] text-muted">Tölts fel egy dokumentumot, és a Claude kinyeri belőle az ügyfél és a szerződés adatait.</p>
</div>

{% if flash %}
  <div class="mb-4 flex items-center gap-2 rounded-xl border px-4 py-3 text-[13.5px] font-medium {{ flash.type == 'error' ? 'border-danger/20 bg-danger/5 text-danger' : 'border-success/20 bg-success/5 text-success' }}">
    <i data-lucide="{{ flash.type == 'error' ? 'alert-circle' : 'check-circle-2' }}" class="h-4 w-4"></i> {{ flash.msg }}
  </div>
{% endif %}

<div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
  <div class="lg:col-span-1">
    <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal/10 text-teal"><i data-lucide="sparkles" class="h-5 w-5"></i></div>
        <h2 class="text-[15px] font-bold text-ink">Dokumentum feltöltése</h2>
      </div>

      <form method="post" action="/admin/ai-kinyeres" enctype="multipart/form-data" class="mt-5">
        <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
        <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Fájl</label>
        <input type="file" name="file" accept=".pdf,.png,.jpg,.jpeg,.webp,application/pdf,image/png,image/jpeg,image/webp" required
          class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[13.5px] outline-none transition file:mr-3 file:rounded-lg file:border-0 file:bg-ink file:px-3 file:py-1.5 file:text-[12.5px] file:font-semibold file:text-white focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
        <p class="mt-2 text-[12px] text-muted">Engedélyezett: PDF, PNG, JPG, JPEG, WEBP. Legfeljebb 20 MB.</p>

        <button type="submit" class="mt-5 flex w-full items-center justify-center gap-2 rounded-xl bg-teal px-5 py-3 text-[14px] font-semibold text-white shadow-soft transition hover:bg-teal/90">
          <i data-lucide="wand-2" class="h-[17px] w-[17px]"></i> Adatok kinyerése AI-val
        </button>
      </form>

      <div class="mt-5 flex items-start gap-2 rounded-xl border border-gold/30 bg-gold/5 px-3.5 py-3 text-[12.5px] text-ink/80">
        <i data-lucide="key-round" class="mt-0.5 h-4 w-4 shrink-0 text-gold"></i>
        <span>A funkció működéséhez az <a href="/admin/beallitasok" class="font-semibold text-teal hover:underline">Anthropic API kulcs</a> beállítása szükséges a Beállításoknál.</span>
      </div>
    </div>
  </div>

  <div class="lg:col-span-2">
    <div class="rounded-2xl border border-slate-200/70 bg-white shadow-card">
      <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
        <h2 class="text-[15px] font-bold text-ink">Jóváhagyásra váró kinyerések</h2>
        <span class="rounded-full bg-surface px-2.5 py-1 text-[12px] font-semibold text-muted">{{ pending|length }}</span>
      </div>

      {% if pending is empty %}
        <div class="px-5 py-16 text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-surface"><i data-lucide="inbox" class="h-7 w-7 text-muted"></i></div>
          <p class="mt-4 text-[14px] font-medium text-ink">Nincs függőben lévő kinyerés</p>
          <p class="mt-1 text-[13px] text-muted">Tölts fel egy dokumentumot a bal oldali űrlapon.</p>
        </div>
      {% else %}
        <div class="overflow-x-auto">
          <table class="w-full text-left text-[13.5px]">
            <thead class="border-b border-slate-100 text-[12px] uppercase tracking-wide text-muted">
              <tr>
                <th class="px-5 py-3 font-semibold">Modell</th>
                <th class="px-5 py-3 font-semibold">Dátum</th>
                <th class="px-5 py-3 font-semibold">Státusz</th>
                <th class="px-5 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {% for e in pending %}
                <tr class="transition hover:bg-surface/60">
                  <td class="px-5 py-3.5 font-medium text-ink">{{ e.model ?: '—' }}</td>
                  <td class="px-5 py-3.5 text-muted">{{ e.created_at }}</td>
                  <td class="px-5 py-3.5">
                    <span class="rounded-full bg-gold/10 px-2.5 py-1 text-[11.5px] font-semibold text-gold">függőben</span>
                  </td>
                  <td class="px-5 py-3.5 text-right">
                    <a href="/admin/ai-kinyeres/{{ e.id }}" class="inline-flex items-center gap-1.5 rounded-lg bg-ink px-3 py-1.5 text-[12.5px] font-semibold text-white transition hover:bg-ink/90">
                      <i data-lucide="search-check" class="h-4 w-4"></i> Ellenőrzés
                    </a>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
