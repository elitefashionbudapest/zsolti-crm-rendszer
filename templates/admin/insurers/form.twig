{% extends 'layouts/admin.twig' %}
{% block title %}{{ mode == 'create' ? 'Új biztosító' : 'Biztosító szerkesztése' }} — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex items-center gap-3">
  <a href="/admin/biztositok" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ mode == 'create' ? 'Új biztosító' : 'Biztosító szerkesztése' }}</h1>
</div>

<form method="post" action="{{ action }}" class="mx-auto max-w-3xl">
  <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
  <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
    <h2 class="text-[15px] font-bold text-ink">Alapadatok</h2>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Név</label>
      <input type="text" name="name" value="{{ insurer.name }}" placeholder="Pl. Generali Biztosító Zrt."
        class="w-full rounded-xl border {{ errors.name is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
      {% if errors.name is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.name }}</p>{% endif %}
    </div>

    <div class="mt-5">
      <label class="mb-1.5 block text-[13px] font-semibold text-ink">Alapértelmezett e-mail címek</label>
      <textarea name="default_emails" rows="4" placeholder="kar@biztosito.hu&#10;ugyfelszolgalat@biztosito.hu"
        class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">{{ insurer.default_emails }}</textarea>
      <p class="mt-1.5 text-[12px] text-muted">Soronként vagy vesszővel elválasztva.</p>
    </div>

    <div class="mt-5">
      <label class="flex items-center gap-2.5 text-[13.5px] font-semibold text-ink">
        <input type="checkbox" name="is_active" value="1" {{ insurer.is_active ? 'checked' }}
          class="h-4 w-4 rounded border-slate-300 text-teal focus:ring-teal/30">
        Aktív biztosító
      </label>
    </div>
  </div>

  <div class="mt-5 flex items-center justify-end gap-3">
    <a href="/admin/biztositok" class="rounded-xl border border-slate-200 px-5 py-3 text-[14px] font-semibold text-ink transition hover:bg-white">Mégse</a>
    <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white transition hover:bg-teal/90">
      <i data-lucide="save" class="h-[17px] w-[17px]"></i> Mentés
    </button>
  </div>
</form>
{% endblock %}
