{% extends 'layouts/base.twig' %}
{% block title %}{{ app_name }} — Modern CRM biztosítási ügynököknek és pénzügyi tanácsadóknak{% endblock %}

{% block head %}
<style>
  /* Apple-keynote finomságok */
  .h-display { letter-spacing: -0.03em; line-height: 1.03; }
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1); }
  .reveal.is-in { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; } }
  /* Finom, lassan úszó fény-folt */
  @keyframes floaty { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-14px) } }
  .floaty { animation: floaty 7s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) { .floaty { animation: none; } }
  /* Kép-szélek elhalványítása átlátszóba — beleolvad a szekcióba (világos/sötét is), nincs doboz */
  .fade-hero { -webkit-mask-image: radial-gradient(125% 115% at 50% 42%, #000 52%, transparent 88%); mask-image: radial-gradient(125% 115% at 50% 42%, #000 52%, transparent 88%); }
  .fade-soft { -webkit-mask-image: radial-gradient(62% 70% at 50% 46%, #000 46%, transparent 74%); mask-image: radial-gradient(62% 70% at 50% 46%, #000 46%, transparent 74%); }
  .hero-card { background: linear-gradient(to bottom, #E3E6EB, #FFFFFF); }
  .dark .hero-card { background: linear-gradient(to bottom, #17233B, #0F1A2E) !important; }
</style>
<noscript><style>.reveal{opacity:1;transform:none}</style></noscript>
{% endblock %}

{% block body %}
<div x-data="{ menuOpen: false }" x-cloak class="min-h-screen bg-surface">

  <div class="mx-auto max-w-6xl px-3 pt-3 sm:px-5 sm:pt-5 lg:max-w-none lg:px-0 lg:pt-0">
    <div class="overflow-hidden rounded-[26px] bg-white shadow-card sm:rounded-[34px] lg:flex lg:min-h-screen lg:flex-col lg:rounded-none lg:shadow-none">

      {# ===== Nav ===== #}
      <header class="flex items-center justify-between px-5 py-4 sm:px-8">
        <a href="/" class="flex items-center gap-2">
          <div class="flex h-8 w-8 items-center justify-center rounded-[10px] bg-ink"><i data-lucide="shield-check" class="h-[18px] w-[18px] text-teal"></i></div>
          <span class="text-[15px] font-bold tracking-tight text-ink">Aegis<span class="text-teal">CRM</span></span>
        </a>
        <nav class="hidden items-center gap-5 md:flex">
          <a href="#funkciok" class="text-[13px] font-medium text-muted transition hover:text-ink">Funkciók</a>
          <span class="h-1 w-1 rounded-full bg-slate-300"></span>
          <a href="#hogyan" class="text-[13px] font-medium text-muted transition hover:text-ink">Hogyan működik</a>
          <span class="h-1 w-1 rounded-full bg-slate-300"></span>
          <a href="#portal" class="text-[13px] font-medium text-muted transition hover:text-ink">Ügyfélportál</a>
        </nav>
        <div class="flex items-center gap-2.5">
          <button type="button" data-theme-toggle aria-label="Sötét vagy világos mód váltása" class="flex h-9 w-9 items-center justify-center rounded-full text-muted transition hover:bg-surface">
            <i data-lucide="moon" class="h-[18px] w-[18px] dark:hidden"></i><i data-lucide="sun" class="hidden h-[18px] w-[18px] dark:block"></i>
          </button>
          <a href="#belepes" class="hidden text-[13px] font-semibold text-ink hover:text-teal sm:inline-flex">Belépés</a>
          <a href="#belepes" class="hidden rounded-full border border-slate-200 bg-white px-4 py-2 text-[13px] font-semibold text-ink shadow-soft transition hover:bg-surface sm:inline-flex">Kezdés — ingyenes</a>
          <button @click="menuOpen = !menuOpen" :aria-expanded="menuOpen" aria-label="Menü" class="flex h-9 w-9 items-center justify-center rounded-full text-ink hover:bg-surface md:hidden">
            <i data-lucide="menu" class="h-5 w-5" x-show="!menuOpen"></i><i data-lucide="x" class="h-5 w-5" x-show="menuOpen"></i>
          </button>
        </div>
      </header>
      <div x-show="menuOpen" x-cloak class="border-t border-slate-100 px-5 py-4 md:hidden">
        <div class="flex flex-col gap-1">
          <a href="#funkciok" @click="menuOpen=false" class="rounded-lg px-3 py-2.5 text-[14px] font-medium text-ink hover:bg-surface">Funkciók</a>
          <a href="#hogyan" @click="menuOpen=false" class="rounded-lg px-3 py-2.5 text-[14px] font-medium text-ink hover:bg-surface">Hogyan működik</a>
          <a href="#portal" @click="menuOpen=false" class="rounded-lg px-3 py-2.5 text-[14px] font-medium text-ink hover:bg-surface">Ügyfélportál</a>
          <a href="#belepes" @click="menuOpen=false" class="mt-1 rounded-lg bg-ink px-3 py-2.5 text-center text-[14px] font-semibold text-white">Belépés</a>
        </div>
      </div>

      {# ===== Hero-kártya ===== #}
      <div class="hero-card relative m-2 rounded-[22px] p-6 sm:m-3 sm:rounded-[28px] sm:p-10 lg:m-0 lg:flex lg:flex-1 lg:items-center lg:rounded-none lg:p-12 xl:p-16">
        <div class="grid w-full items-center gap-10 lg:mx-auto lg:max-w-7xl lg:grid-cols-2">

          {# bal: szöveg #}
          <div>
            <div class="reveal flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-ink"><i data-lucide="sparkles" class="h-4 w-4 text-teal"></i></div>
              <div class="text-[12.5px] leading-tight"><div class="font-bold text-ink">Ügynököknek &amp; tanácsadóknak</div><div class="text-muted">Egy rendszerben minden</div></div>
            </div>
            <h1 class="h-display reveal mt-6 text-[68px] font-bold tracking-tighter text-ink sm:text-[92px] lg:text-[108px]">Növekedj<span class="align-super text-[0.34em] font-bold text-teal">+</span></h1>
            <p class="reveal mt-3 max-w-md text-[15.5px] leading-relaxed text-muted sm:text-[16.5px]">Kevesebb adminisztráció, több ügyfél — AI-adatkinyeréssel és automatikus dokumentumkitöltéssel, akár tízszer gyorsabban.</p>

            <div class="reveal mt-7 flex items-center gap-5">
              <div class="flex items-center gap-2.5">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-teal/10"><i data-lucide="shield-check" class="h-[18px] w-[18px] text-teal"></i></div>
                <div class="text-[12.5px] leading-tight"><div class="font-semibold text-ink">100% papírmentes</div><div class="text-muted">Banki szintű titkosítás</div></div>
              </div>
              <div class="h-9 w-px bg-slate-200"></div>
              <div class="flex items-center gap-1.5 text-[13px] font-semibold text-ink"><i data-lucide="lock" class="h-4 w-4 text-teal"></i> GDPR</div>
            </div>

            <div class="reveal mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
              <a href="#belepes" class="inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3.5 text-[14.5px] font-semibold text-white transition hover:-translate-y-0.5 hover:bg-ink/90">Ügynöki belépés <i data-lucide="arrow-right" class="h-[17px] w-[17px]"></i></a>
              <a href="#belepes" class="inline-flex items-center gap-1.5 text-[14px] font-semibold text-ink transition hover:text-teal">Ügyfél belépés <i data-lucide="arrow-up-right" class="h-4 w-4"></i></a>
            </div>
          </div>

          {# jobb: portré + üveges kártyák #}
          <div class="reveal relative">
            <div class="relative mx-auto max-w-[380px] lg:max-w-[440px] xl:max-w-[500px]">
              <div class="aspect-[3/4] overflow-hidden rounded-[26px] bg-ink shadow-float">
                <img src="/img/advisor.webp" width="896" height="1200" fetchpriority="high"
                  alt="AegisCRM — pénzügyi tanácsadó" class="h-full w-full object-cover">
              </div>

              {# chat-buborékok #}
              <div class="absolute left-[-5%] top-[24%] flex items-center gap-2 rounded-full bg-white/90 px-3.5 py-2 shadow-card backdrop-blur">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-teal text-white"><i data-lucide="check" class="h-3 w-3"></i></span><span class="text-[12px] font-semibold text-ink">Lejár a szerződése?</span>
              </div>
              <div class="absolute left-[2%] top-[38%] flex items-center gap-2 rounded-full bg-white/90 px-3.5 py-2 shadow-card backdrop-blur">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-gold text-ink"><i data-lucide="check" class="h-3 w-3"></i></span><span class="text-[12px] font-semibold text-ink">Új ajánlat kész</span>
              </div>

              {# stat üvegkártya (jobb felül) #}
              <div class="absolute right-[-7%] top-[7%] w-[128px] rounded-2xl border border-white/50 bg-white/70 p-3.5 shadow-card backdrop-blur-md">
                <div class="text-[10px] font-semibold uppercase tracking-wide text-muted">— akár</div>
                <div class="text-[30px] font-bold leading-none text-ink">10×</div>
                <div class="mt-1 text-[11px] leading-tight text-muted">gyorsabb ügyintézés</div>
              </div>

              {# kötvény üvegkártya (jobb alul) #}
              <div class="absolute bottom-[7%] right-[-9%] flex w-[210px] items-center gap-3 rounded-2xl border border-white/50 bg-white/80 p-3 shadow-card backdrop-blur-md">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-ink"><i data-lucide="house" class="h-6 w-6 text-teal"></i></div>
                <div class="min-w-0">
                  <div class="truncate text-[12.5px] font-bold text-ink">Otthonbiztosítás</div>
                  <div class="text-[15px] font-bold leading-tight text-ink">48 900 Ft<span class="text-[11px] font-medium text-muted">/év</span></div>
                  <div class="mt-0.5 flex items-center gap-1 text-[11px] font-semibold text-success"><i data-lucide="badge-check" class="h-3.5 w-3.5"></i> aktív</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {# ===== Biztosító-szalag ===== #}
      <div class="flex flex-wrap items-center justify-center gap-x-9 gap-y-3 px-6 pb-8 pt-4 sm:gap-x-12 sm:px-10">
        {% for logo in ['Allianz','Generali','Groupama','UNION','UNIQA','K&H'] %}
          <span class="text-[15px] font-bold tracking-tight text-slate-400 grayscale">{{ logo }}</span>
        {% endfor %}
      </div>

    </div>
  </div>

  {# ===== Trust szalag ===== #}
  <section class="border-b border-slate-100 bg-white">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-x-6 gap-y-6 px-5 py-10 sm:px-8 lg:grid-cols-4">
      {% for t in trust %}
        <div class="reveal flex items-center gap-3">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-surface"><i data-lucide="{{ t.icon }}" class="h-5 w-5 text-teal"></i></div>
          <div class="text-[13px] font-semibold leading-tight text-ink">{{ t.label }}</div>
        </div>
      {% endfor %}
    </div>
  </section>

  {# ===== Funkciók ===== #}
  <section id="funkciok" class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="reveal mx-auto max-w-3xl text-center">
        <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-teal">Funkciók</div>
        <h2 class="h-display mt-4 text-[34px] font-bold text-ink sm:text-[48px]">Minden, ami a napi munkához kell.</h2>
        <p class="mt-5 text-[16px] leading-relaxed text-muted">Egyetlen rendszer, amely a partnerkezeléstől az AI-adatkinyerésen át a biztosítói küldésig mindent lefed.</p>
      </div>
      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {% for f in features %}
          <div class="reveal group rounded-3xl border border-slate-200/70 bg-white p-7 transition hover:-translate-y-1 hover:border-teal/30 hover:shadow-card">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-ink to-teal shadow-soft transition group-hover:scale-105"><i data-lucide="{{ f.icon }}" class="h-6 w-6 text-white"></i></div>
            <h3 class="mt-6 text-[18px] font-bold tracking-tight text-ink">{{ f.title }}</h3>
            <p class="mt-2.5 text-[14.5px] leading-relaxed text-muted">{{ f.desc }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ===== Kiemelt: AI-adatkinyerés (2 oszlop) ===== #}
  <section class="bg-ink py-24 sm:py-32">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-2">
      <div class="reveal">
        <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-teal">AI-adatkinyerés</div>
        <p class="h-display mt-5 text-[30px] font-bold text-white sm:text-[44px]">
          Dokumentumból kész szerződés — <span class="text-slate-400">kézi gépelés nélkül.</span>
        </p>
        <p class="mt-6 max-w-md text-[16px] leading-relaxed text-slate-300 sm:text-[17px]">Töltsd fel a PDF-et vagy a szkennelt oldalt. Az AI másodpercek alatt kiolvassa és strukturálja az adatokat, te pedig csak jóváhagyod.</p>
        <div class="mt-8 flex flex-col gap-3.5">
          {% for m in [['zap','Másodpercek alatt kész'],['target','Pontos, ellenőrizhető kinyerés'],['file-check-2','Automatikus dokumentumkitöltés']] %}
            <div class="flex items-center gap-3 text-[15px] font-semibold text-white"><span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/10"><i data-lucide="{{ m[0] }}" class="h-[18px] w-[18px] text-teal"></i></span>{{ m[1] }}</div>
          {% endfor %}
        </div>
      </div>
      {# jobb: CSS-vizuál — átlátszó, glow-k a háttérbe olvadnak (dokumentum → kinyert mezők) #}
      <div class="reveal relative flex justify-center">
        <div class="pointer-events-none absolute left-1/2 top-1/2 h-80 w-80 -translate-x-1/2 -translate-y-1/2 rounded-full bg-teal/25 blur-[100px]"></div>
        <div class="pointer-events-none absolute right-4 top-2 h-44 w-44 rounded-full bg-gold/20 blur-[90px]"></div>

        <div class="relative w-full max-w-sm">
          <div class="floaty mx-auto mb-5 flex w-60 items-center gap-3 rounded-2xl border border-white/10 bg-white/5 p-3 backdrop-blur">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-white/10"><i data-lucide="file-text" class="h-5 w-5 text-white"></i></div>
            <div class="min-w-0"><div class="truncate text-[13px] font-semibold text-white">szerzodes.pdf</div><div class="text-[11px] text-slate-400">feltöltve · 1,2 MB</div></div>
          </div>

          <div class="mb-5 flex items-center justify-center gap-2 text-[12px] font-semibold text-teal"><i data-lucide="sparkles" class="h-4 w-4"></i> AI kiolvasás <i data-lucide="arrow-down" class="h-4 w-4"></i></div>

          <div class="rounded-3xl border border-white/10 bg-white/[0.06] p-5 shadow-float backdrop-blur-xl">
            {% for r in [['Ügyfél neve','Kovács Anna'],['Kötvényszám','HU-2026-48192'],['Évforduló','2026. 09. 14.'],['Éves díj','48 900 Ft']] %}
              <div class="flex items-center justify-between border-b border-white/5 py-2.5 last:border-0 last:pb-0">
                <span class="text-[12.5px] text-slate-400">{{ r[0] }}</span>
                <span class="flex items-center gap-1.5 text-[13.5px] font-semibold text-white">{{ r[1] }} <i data-lucide="check" class="h-3.5 w-3.5 text-teal"></i></span>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ===== Hogyan működik ===== #}
  <section id="hogyan" class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="reveal mx-auto max-w-3xl text-center">
        <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-teal">Hogyan működik</div>
        <h2 class="h-display mt-4 text-[34px] font-bold text-ink sm:text-[48px]">Négy lépés a kész szerződésig.</h2>
      </div>
      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {% for s in steps %}
          <div class="reveal relative flex flex-col items-center text-center">
            <div class="relative flex h-16 w-16 items-center justify-center rounded-2xl bg-ink text-white shadow-card">
              <i data-lucide="{{ s.icon }}" class="h-7 w-7"></i>
              <span class="absolute -right-2 -top-2 flex h-7 w-7 items-center justify-center rounded-full bg-teal text-[13px] font-bold text-white ring-4 ring-white">{{ s.num }}</span>
            </div>
            <h3 class="mt-6 text-[17px] font-bold tracking-tight text-ink">{{ s.title }}</h3>
            <p class="mt-2 max-w-[240px] text-[14px] leading-relaxed text-muted">{{ s.desc }}</p>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ===== Ügyfélportál (telefon-mockup) ===== #}
  <section id="portal" class="overflow-hidden bg-surface py-24 sm:py-32">
    <div class="mx-auto grid max-w-7xl items-center gap-14 px-5 sm:px-8 lg:grid-cols-2">
      <div class="reveal">
        <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-teal">Ügyfélportál</div>
        <h2 class="h-display mt-4 text-[32px] font-bold text-ink sm:text-[44px]">Az ügyfeleid külön, biztonságos felülete.</h2>
        <p class="mt-5 text-[16px] leading-relaxed text-muted">Szerződések, dokumentumok és határidők — mobilról is, bármikor. Kevesebb telefon, kevesebb e-mail, elégedettebb ügyfelek.</p>
        <ul class="mt-7 space-y-3.5">
          {% for p in ['Szerződések és évfordulók áttekinthetően','Dokumentumok biztonságos letöltése','Közvetlen üzenet az ügynöknek'] %}
            <li class="flex items-center gap-3 text-[15px] font-medium text-ink"><span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-teal/10"><i data-lucide="check" class="h-4 w-4 text-teal"></i></span>{{ p }}</li>
          {% endfor %}
        </ul>
      </div>
      {# ==== Telefon: éles CSS-mockup (mindkét módban tiszta) ==== #}
      <div class="reveal flex justify-center">
        <div class="relative">
          <div class="pointer-events-none absolute -inset-6 rounded-[64px] bg-teal/15 blur-3xl"></div>
          <div class="floaty relative w-[280px] rounded-[46px] border-[10px] border-ink bg-ink p-1.5 shadow-float sm:w-[300px]">
            <div class="overflow-hidden rounded-[36px] bg-surface">
              <div class="flex items-center justify-between bg-white px-5 pb-3 pt-5">
                <div><div class="text-[11px] text-muted">Üdv,</div><div class="text-[15px] font-bold text-ink">Kovács Anna</div></div>
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-ink text-[12px] font-bold text-white">KA</div>
              </div>
              <div class="space-y-3 p-4">
                <div class="grid grid-cols-2 gap-2.5">
                  <div class="rounded-2xl border border-slate-200/70 bg-white p-3"><div class="flex h-8 w-8 items-center justify-center rounded-lg bg-ink/5"><i data-lucide="calendar-heart" class="h-[17px] w-[17px] text-ink"></i></div><div class="mt-2.5 text-[13px] font-bold text-ink">09. 14.</div><div class="text-[10.5px] text-muted">Évforduló</div></div>
                  <div class="rounded-2xl border border-slate-200/70 bg-white p-3"><div class="flex h-8 w-8 items-center justify-center rounded-lg bg-warning/10"><i data-lucide="clock-alert" class="h-[17px] w-[17px] text-warning"></i></div><div class="mt-2.5 text-[13px] font-bold text-ink">30 nap</div><div class="text-[10.5px] text-muted">Lejárat</div></div>
                </div>
                <div class="rounded-2xl border border-slate-200/70 bg-white p-3.5">
                  <div class="mb-2 flex items-center justify-between"><span class="text-[12px] font-bold text-ink">Szerződéseim</span><span class="text-[10.5px] font-semibold text-teal">Összes</span></div>
                  {% for c in [['house','Otthonbiztosítás','48 900 Ft/év'],['heart-pulse','Életbiztosítás','12 400 Ft/hó'],['car','Kötelező gfb','31 200 Ft/év']] %}
                    <div class="flex items-center gap-3 py-2">
                      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-surface"><i data-lucide="{{ c[0] }}" class="h-[18px] w-[18px] text-ink"></i></div>
                      <div class="min-w-0 flex-1"><div class="truncate text-[12px] font-semibold text-ink">{{ c[1] }}</div><div class="text-[10.5px] text-muted">{{ c[2] }}</div></div>
                      <span class="rounded-full bg-success/10 px-2 py-0.5 text-[9.5px] font-semibold text-success">aktív</span>
                    </div>
                  {% endfor %}
                </div>
                <div class="flex h-11 items-center justify-center gap-2 rounded-2xl bg-teal text-[13px] font-semibold text-white"><i data-lucide="message-circle" class="h-4 w-4"></i> Ügynök írása</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {# ===== Belépés ===== #}
  <section id="belepes" class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <div class="reveal mx-auto max-w-3xl text-center">
        <div class="text-[13px] font-bold uppercase tracking-[0.14em] text-teal">Belépés</div>
        <h2 class="h-display mt-4 text-[34px] font-bold text-ink sm:text-[48px]">Két felület, egy rendszer.</h2>
      </div>
      <div class="reveal mt-14 grid grid-cols-1 gap-6 md:grid-cols-2">
