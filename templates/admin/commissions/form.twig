{% extends 'layouts/admin.twig' %}
{% block title %}{{ mode == 'create' ? 'Új jutalék' : 'Jutalék szerkesztése' }} — {{ app_name }}{% endblock %}

{% block main %}
<div class="mb-6 flex items-center gap-3">
  <a href="/admin/jutalekok" class="flex h-9 w-9 items-center justify-center rounded-lg text-muted hover:bg-white"><i data-lucide="arrow-left" class="h-5 w-5"></i></a>
  <h1 class="text-[22px] font-bold tracking-tight text-ink sm:text-[26px]">{{ mode == 'create' ? 'Új jutalék' : 'Jutalék szerkesztése' }}</h1>
</div>

<form method="post" action="{{ action }}" class="mx-auto max-w-3xl">
  <input type="hidden" name="{{ csrf.keys.name }}" value="{{ csrf.name }}">
  <input type="hidden" name="{{ csrf.keys.value }}" value="{{ csrf.value }}">

  <div class="rounded-2xl border border-slate-200/70 bg-white p-6 shadow-card sm:p-7">
    <h2 class="text-[15px] font-bold text-ink">Jutalék adatai</h2>
    <div class="mt-5 grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Szerződés</label>
        <select name="contract_id" class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
          <option value="">— Nincs hozzárendelve —</option>
          {% for ct in contracts %}
            <option value="{{ ct.id }}" {{ commission.contract_id == ct.id ? 'selected' }}>{{ ct.label }}</option>
          {% endfor %}
        </select>
      </div>

      <div>
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Összeg (Ft)</label>
        <input type="number" step="0.01" name="amount" value="{{ commission.amount }}" placeholder="Pl. 45000"
          class="w-full rounded-xl border {{ errors.amount is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
        {% if errors.amount is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.amount }}</p>{% endif %}
      </div>

      <div>
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Státusz</label>
        <select name="status" class="w-full rounded-xl border border-slate-200 bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
          <option value="pending" {{ commission.status == 'pending' ? 'selected' }}>Függő</option>
          <option value="settled" {{ commission.status == 'settled' ? 'selected' }}>Rendezett</option>
        </select>
      </div>

      <div>
        <label class="mb-1.5 block text-[13px] font-semibold text-ink">Rendezés dátuma</label>
        <input type="date" name="settled_at" value="{{ commission.settled_at }}"
          class="w-full rounded-xl border {{ errors.settled_at is defined ? 'border-danger' : 'border-slate-200' }} bg-surface px-4 py-3 text-[14px] outline-none transition focus:border-teal focus:bg-white focus:ring-2 focus:ring-teal/15">
        {% if errors.settled_at is defined %}<p class="mt-1 text-[12px] font-medium text-danger">{{ errors.settled_at }}</p>{% endif %}
      </div>
    </div>
  </div>

  <div class="mt-5 flex items-center justify-end gap-3">
    <a href="/admin/jutalekok" class="rounded-xl border border-slate-200 px-5 py-3 text-[14px] font-semibold text-ink transition hover:bg-white">Mégse</a>
    <button type="submit" class="flex items-center gap-2 rounded-xl bg-teal px-6 py-3 text-[14.5px] font-semibold text-white transition hover:bg-teal/90">
      <i data-lucide="save" class="h-[17px] w-[17px]"></i> Mentés
    </button>
  </div>
</form>
{% endblock %}
