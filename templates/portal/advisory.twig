{% extends 'layouts/portal.twig' %}
{% block title %}Tanácsadói anyagok — Ügyfélportál{% endblock %}

{% block main %}
<h1 class="text-[26px] font-bold tracking-tight text-ink sm:text-[30px]">Tanácsadói anyagok</h1>
<p class="mt-1.5 text-[15px] text-muted">Hasznos összefoglalók és tippek, amelyeket tanácsadója állított össze Önnek.</p>

{% if rows is empty %}
  <div class="mt-7 rounded-2xl border border-slate-200/70 bg-white px-5 py-12 text-center shadow-soft">
    <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-surface"><i data-lucide="book-open" class="h-6 w-6 text-muted"></i></div>
    <p class="mt-3 text-[14px] font-medium text-ink">Még nincs elérhető anyag</p>
    <p class="mt-1 text-[13.5px] text-muted">Amint tanácsadója megoszt Önnel egy anyagot, itt fog megjelenni.</p>
  </div>
{% else %}
  <div class="mt-7 grid grid-cols-1 gap-4 sm:grid-cols-2">
    {% for r in rows %}
      <div class="flex flex-col rounded-2xl border border-slate-200/70 bg-white p-5 shadow-soft">
        <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-teal/10"><i data-lucide="book-open" class="h-[22px] w-[22px] text-teal"></i></div>
        <h2 class="mt-4 text-[16px] font-bold text-ink">{{ r.title }}</h2>
        {% if r.body %}
          <p class="mt-1.5 line-clamp-3 text-[13.5px] text-muted">{{ r.body|striptags|slice(0, 160) }}{{ r.body|length > 160 ? '…' }}</p>
        {% endif %}
        <a href="/portal/tanacsadas/{{ r.id }}" class="mt-4 inline-flex items-center gap-1.5 text-[13.5px] font-semibold text-teal transition hover:text-teal/80">
          Elolvasom <i data-lucide="arrow-right" class="h-4 w-4"></i>
        </a>
      </div>
    {% endfor %}
  </div>
{% endif %}
{% endblock %}
